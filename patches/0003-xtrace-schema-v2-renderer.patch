+uint64_t XTraceLogger::BeginActivation(const char* category,
+                                       const char* api,
+                                       const String& args_json,
+                                       const String& frame_url,
+                                       const String& origin) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!blink::CausalitySyncEnabled(config) ||
+      !CategoryEnabled(config, category)) {
+    return 0;
+  }
+
+  std::vector<XTraceActivation>& stack = ActivationStack();
+  XTraceActivation activation;
+  activation.token = NextActivationSequenceNumber();
+  activation.api = api;
+  activation.started_mono_us =
+      base::TimeTicks::Now().since_origin().InMicroseconds();
+  if (!stack.empty()) {
+    activation.parent_token = stack.back().token;
+    activation.depth = stack.back().depth + 1;
+  }
+
+  CausalityFields fields;
+  fields.call_token = activation.token;
+  fields.parent_token = activation.parent_token;
+  fields.depth = activation.depth;
+  fields.kind = "paired";
+  fields.has_parent = activation.parent_token != 0;
+  const uint64_t seq = NextSequenceNumber();
+  LogEventWithSequence(config, category, "call", api, args_json, seq,
+                       std::string_view(), false, frame_url.Utf8(),
+                       origin.Utf8(), &fields);
+  stack.push_back(std::move(activation));
+  return stack.back().token;
+}
+
+void XTraceLogger::CompleteActivation(uint64_t token) {
+  if (!token) {
+    return;
+  }
+  std::vector<XTraceActivation>& stack = ActivationStack();
+  if (!stack.empty() && stack.back().token == token) {
+    stack.pop_back();
+  }
+}
+
+void XTraceLogger::AbandonActivation(uint64_t token) {
+  // We intentionally do not synthesize a terminal event here: a scope can be
+  // abandoned before Blink has a ScriptEvaluationResult. The RAII path exists
+  // solely to keep subsequent events from inheriting a stale parent.
+  CompleteActivation(token);
+}
