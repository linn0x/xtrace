+void AppendRegExpResultArrayJson(Isolate* isolate,
+                                 std::string& args,
+                                 bool* has_field,
+                                 DirectHandle<Object> result) {
+  AppendFieldPrefix(args, has_field, "result_length");
+  if (!IsJSArray(*result)) {
+    args.append("null");
+    AppendFieldPrefix(args, has_field, "captures");
+    args.append("null");
+    AppendFieldPrefix(args, has_field, "capture_refs");
+    args.append("null");
+    AppendFieldPrefix(args, has_field, "captures_complete");
+    args.append(IsNull(*result) ? "true" : "false");
+    return;
+  }
+
+  DirectHandle<JSArray> result_array = Cast<JSArray>(result);
+  DirectHandle<Object> raw_length(result_array->length(), isolate);
+  args.append(JsonValue(raw_length));
+
+  uint32_t length = 0;
+  bool captures_complete = Object::ToArrayLength(*raw_length, &length);
+  DirectHandle<FixedArrayBase> elements_base(result_array->elements(), isolate);
+  const bool can_read_elements =
+      captures_complete && IsFixedArray(*elements_base);
+
+  AppendFieldPrefix(args, has_field, "captures");
+  if (!can_read_elements) {
+    args.append("null");
+  } else {
+    Tagged<FixedArray> elements = Cast<FixedArray>(*elements_base);
+    const uint32_t element_count = static_cast<uint32_t>(elements->length());
+    if (length > element_count) captures_complete = false;
+    const uint32_t readable_count = std::min(length, element_count);
+    args.push_back('[');
+    for (uint32_t i = 0; i < readable_count; ++i) {
+      if (i > 0) args.push_back(',');
+      Tagged<Object> raw_element = elements->get(i);
+      if (IsTheHole(raw_element)) {
+        captures_complete = false;
+        args.append("null");
+      } else {
+        DirectHandle<Object> element(raw_element, isolate);
+        args.append(JsonValue(element));
+      }
+    }
+    args.push_back(']');
+  }
+
+  AppendFieldPrefix(args, has_field, "capture_refs");
+  if (!can_read_elements) {
+    args.append("null");
+  } else {
+    Tagged<FixedArray> elements = Cast<FixedArray>(*elements_base);
+    const uint32_t element_count = static_cast<uint32_t>(elements->length());
+    const uint32_t readable_count = std::min(length, element_count);
+    args.push_back('[');
+    for (uint32_t i = 0; i < readable_count; ++i) {
+      if (i > 0) args.push_back(',');
+      Tagged<Object> raw_element = elements->get(i);
+      if (IsTheHole(raw_element)) {
+        args.append(QuoteJson("hole"));
+      } else {
+        DirectHandle<Object> element(raw_element, isolate);
+        args.append(QuoteJson(XTraceValueRef(isolate, element)));
+      }
+    }
+    args.push_back(']');
+  }
+
+  AppendFieldPrefix(args, has_field, "captures_complete");
+  args.append(captures_complete ? "true" : "false");
+}
