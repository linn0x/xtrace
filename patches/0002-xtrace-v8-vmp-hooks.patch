+void AppendFieldPrefix(std::string& args, bool* has_field, const char* name) {
+  // Prefer has_field tracking, but recover when a prior writer left the buffer
+  // mid-object without flipping has_field (observed as ...:length:N""result").
+  if (!args.empty()) {
+    const char last = args.back();
+    const bool needs_comma =
+        (*has_field && last != ',') ||
+        (!*has_field && last != '{' && last != '[' && last != ',');
+    if (needs_comma) {
+      args.push_back(',');
+    }
+  }
+  args.push_back('"');
+  args.append(name);
+  args.append("\":");
+  *has_field = true;
+}
+
+
+std::string QuoteJson(std::string_view value) {
+  std::string quoted = "\"";
+  for (char c : value) {
+    switch (c) {
+      case '"':
+        quoted.append("\\\"");
+        break;
+      case '\\':
+        quoted.append("\\\\");
+        break;
+      case '\n':
+        quoted.append("\\n");
+        break;
+      case '\r':
+        quoted.append("\\r");
+        break;
+      case '\t':
+        quoted.append("\\t");
+        break;
+      default:
+        if (static_cast<unsigned char>(c) < 0x20) {
+          quoted.append(" ");
+        } else {
+          quoted.push_back(c);
+        }
+    }
+  }
+  quoted.push_back('"');
+  return quoted;
+}
