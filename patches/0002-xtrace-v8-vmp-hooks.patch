+bool XTraceIsPresentValue(DirectHandle<Object> value) {
+  return !IsUndefined(*value) && !IsNull(*value);
+}
+
+bool XTraceIsCallableHandler(DirectHandle<Object> value) {
+  return IsCallable(*value);
+}
+
+const char* XTracePromiseHandlerRole(DirectHandle<Object> on_fulfilled,
+                                     DirectHandle<Object> on_rejected) {
+  const bool has_on_fulfilled = XTraceIsCallableHandler(on_fulfilled);
+  const bool has_on_rejected = XTraceIsCallableHandler(on_rejected);
+  if (has_on_fulfilled && has_on_rejected) return "both";
+  if (has_on_fulfilled) return "fulfillment";
+  if (has_on_rejected) return "rejection";
+  return "none";
+}
