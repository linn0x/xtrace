+std::string XTraceQuoteJson(const std::string& value) {
+  std::string quoted = "\"";
+  for (char c : value) {
+    switch (c) {
+      case '"':
+        quoted.append("\\\"");
+        break;
+      case '\\':
+        quoted.append("\\\\");
+        break;
+      case '\n':
+        quoted.append("\\n");
+        break;
+      case '\r':
+        quoted.append("\\r");
+        break;
+      case '\t':
+        quoted.append("\\t");
+        break;
+      default:
+        if (static_cast<unsigned char>(c) < 0x20) {
+          quoted.append(" ");
+        } else {
+          quoted.push_back(c);
+        }
+    }
+  }
+  quoted.push_back('"');
+  return quoted;
+}
+
+std::string XTraceStableStringRef(DirectHandle<String> value) {
+  std::unique_ptr<char[]> captured = value->ToCString();
+  uint64_t hash = 1469598103934665603ULL;
+  for (const unsigned char* cursor =
+           reinterpret_cast<const unsigned char*>(captured.get());
+       *cursor != '\0'; ++cursor) {
+    hash ^= *cursor;
+    hash *= 1099511628211ULL;
+  }
+  return std::string("string_ref:fnv1a64:") + std::to_string(hash) +
+         ":length:" + std::to_string(value->length());
+}
+
+void AppendXTraceStringField(std::string& event,
