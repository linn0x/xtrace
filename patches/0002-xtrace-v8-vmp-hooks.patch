+namespace {
+
+bool XTracePropertyDefineLoggingEnabled(Isolate* isolate) {
+  if (isolate->serializer_enabled()) return false;
+
+  constexpr uint32_t kXTraceEmbedderDataSlot = 3;
+  constexpr uintptr_t kXTraceEmbedderDataMarker = 0x5854524143450ULL;
+  return isolate->event_logger() &&
+         isolate->GetData(kXTraceEmbedderDataSlot) ==
+             reinterpret_cast<void*>(kXTraceEmbedderDataMarker);
+}
+
+std::string XTraceQuoteJson(const std::string& value) {
+  std::string quoted;
+  quoted.reserve(value.size() + 2);
+  quoted.push_back('"');
+  for (char c : value) {
+    switch (c) {
+      case '"':
+        quoted.append("\\\"");
+        break;
+      case '\\':
+        quoted.append("\\\\");
+        break;
+      case '\n':
+        quoted.append("\\n");
+        break;
+      case '\r':
+        quoted.append("\\r");
+        break;
+      case '\t':
+        quoted.append("\\t");
+        break;
+      default:
+        if (static_cast<unsigned char>(c) < 0x20) {
+          quoted.append(" ");
+        } else {
+          quoted.push_back(c);
+        }
+    }
+  }
+  quoted.push_back('"');
+  return quoted;
+}
+
+std::string XTraceObjectType(DirectHandle<Object> value) {
+  if (IsUndefined(*value)) return "undefined";
+  if (IsNull(*value)) return "null";
+  if (IsTrue(*value) || IsFalse(*value)) return "boolean";
+  if (IsSmi(*value)) return "smi";
+  if (IsHeapNumber(*value)) return "number";
+  if (IsBigInt(*value)) return "bigint";
+  if (IsString(*value)) return "string";
+  if (IsSymbol(*value)) return "symbol";
+  if (IsJSArray(*value)) return "array";
+  if (IsJSFunction(*value)) return "function";
+  if (IsJSReceiver(*value)) return "object";
+  return "value";
+}
+
+std::string XTraceValueRef(Isolate* isolate, DirectHandle<Object> value) {
+  if (IsJSReceiver(*value)) {
+    return std::string("object:") +
+           std::to_string(Object::GetOrCreateHash(*value, isolate).value());
+  }
+  if (IsUndefined(*value)) return "undefined";
+  if (IsNull(*value)) return "null";
+  if (IsTrue(*value)) return "boolean:true";
+  if (IsFalse(*value)) return "boolean:false";
+  if (IsNumber(*value)) {
+    const double number = Object::NumberValue(*value);
+    if (!std::isfinite(number)) return "number:nonfinite";
+    return std::string("number:") + std::to_string(number);
+  }
+  if (IsBigInt(*value)) {
+    return "bigint";
+  }
+  if (IsString(*value)) {
+    DirectHandle<String> string = Cast<String>(value);
+    std::unique_ptr<char[]> captured = string->ToCString();
+    return std::string("string:") + captured.get();
+  }
+  return XTraceObjectType(value);
+}
+
+std::string XTraceJsonValue(DirectHandle<Object> value) {
+  if (IsUndefined(*value) || IsNull(*value)) return "null";
+  if (IsTrue(*value)) return "true";
+  if (IsFalse(*value)) return "false";
+  if (IsNumber(*value)) {
+    const double number = Object::NumberValue(*value);
+    if (!std::isfinite(number)) return "null";
+    return std::to_string(number);
+  }
+  if (IsString(*value)) {
+    std::unique_ptr<char[]> text = Cast<String>(value)->ToCString();
+    return XTraceQuoteJson(text.get());
+  }
+  return "null";
+}
+
+void XTraceAppendFieldPrefix(std::string& args,
+                             bool* has_field,
+                             const char* field_name) {
+  if (*has_field) args.push_back(',');
+  args.push_back('"');
+  args.append(field_name);
+  args.append("\":");
+  *has_field = true;
+}
+
+void XTraceAppendValueRefJson(Isolate* isolate,
+                              std::string& args,
+                              bool* has_field,
+                              const char* field_name,
+                              DirectHandle<Object> value) {
+  XTraceAppendFieldPrefix(args, has_field, field_name);
+  args.append(XTraceQuoteJson(XTraceValueRef(isolate, value)));
+}
+
+void XTraceAppendObjectIdJson(Isolate* isolate,
+                              std::string& args,
+                              bool* has_field,
+                              const char* field_name,
+                              DirectHandle<Object> value) {
+  XTraceAppendFieldPrefix(args, has_field, field_name);
+  if (!IsJSReceiver(*value)) {
+    args.append("null");
+    return;
+  }
+  args.append(
+      std::to_string(Object::GetOrCreateHash(*value, isolate).value()));
+}
+
+void XTraceAppendObjectTypeJson(std::string& args,
+                                bool* has_field,
+                                const char* field_name,
+                                DirectHandle<Object> value) {
+  XTraceAppendFieldPrefix(args, has_field, field_name);
+  args.append(XTraceQuoteJson(XTraceObjectType(value)));
+}
+
