+const char* XTraceObjectType(DirectHandle<Object> value) {
+  if (IsUndefined(*value)) return "undefined";
+  if (IsNull(*value)) return "null";
+  if (IsJSFunction(*value)) return "function";
+  if (IsJSArray(*value)) return "array";
+  if (IsJSTypedArray(*value)) return "typed_array";
+  if (IsJSArrayBuffer(*value)) return "array_buffer";
+  if (IsBigInt(*value)) return "bigint";
+  if (IsString(*value)) return "string";
+  if (IsNumber(*value)) return "number";
+  if (IsBoolean(*value)) return "boolean";
+  if (IsJSReceiver(*value)) return "object";
+  return "other";
+}
