+void AppendXTraceVmpStackFrameJson(Isolate* isolate,
+                                   std::string& args,
+                                   JavaScriptFrame* frame,
+                                   int frame_index) {
+  FrameSummary summary = FrameSummary::GetInnermost(frame);
+  summary.EnsureSourcePositionsAvailable();
+
+  args.append("{\"index\":");
+  args.append(std::to_string(frame_index));
+  args.append(",\"function\":");
+  if (summary.IsJavaScript()) {
+    DirectHandle<JSFunction> function = summary.AsJavaScript().function();
+    DirectHandle<String> name = JSFunction::GetDebugName(isolate, function);
+    std::unique_ptr<char[]> name_text = name->ToCString();
+    args.append(QuoteJson(name_text.get()));
+  } else {
+    args.append("null");
+  }
+
+  args.append(",\"script\":");
+  DirectHandle<Object> script_object = summary.script();
+  if (IsScript(*script_object)) {
+    DirectHandle<Script> script = Cast<Script>(script_object);
+    DirectHandle<Object> script_name(script->GetNameOrSourceURL(), isolate);
+    AppendNullableTaggedStringJson(args, script_name);
+    const int source_position = summary.SourcePosition();
+    Script::PositionInfo info;
+    if (source_position != kNoSourcePosition &&
+        Script::GetPositionInfo(script, source_position, &info)) {
+      args.append(",\"line\":");
+      args.append(std::to_string(info.line + 1));
+      args.append(",\"column\":");
+      args.append(std::to_string(info.column + 1));
+    } else {
+      args.append(",\"line\":null,\"column\":null");
+    }
+    args.append(",\"source_position\":");
+    args.append(std::to_string(source_position));
+  } else {
+    args.append("null,\"line\":null,\"column\":null,\"source_position\":null");
+  }
+
+  args.append(",\"code_offset\":");
+  args.append(std::to_string(summary.code_offset()));
+  args.push_back('}');
+}
