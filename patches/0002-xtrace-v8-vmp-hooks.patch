+std::string JsonValue(DirectHandle<Object> value) {
+  if (IsUndefined(*value) || IsNull(*value)) return "null";
+  if (IsTrue(*value)) return "true";
+  if (IsFalse(*value)) return "false";
+  if (IsNumber(*value)) {
+    const double number = Object::NumberValue(*value);
+    if (!std::isfinite(number)) return "null";
+    return std::to_string(number);
+  }
+  if (IsString(*value)) {
+    std::unique_ptr<char[]> text = Cast<String>(value)->ToCString();
+    return QuoteJson(text.get());
+  }
+  return "null";
+}
