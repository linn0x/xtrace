+// XTrace: emit WebAssembly JS-API boundary events over the same event_logger
+// channel V8's VMP-runtime hooks use (the renderer maps "xtrace:vmp-runtime:"
+// to the "reverse" category). These are plain C++-callback hooks at the WASM
+// JS API surface -- no generated trampolines -- so they cannot destabilise the
+// engine. They make WASM signers visible (instantiation/compile boundary +
+// module byte size); per-call JS<->WASM argument capture is out of scope here.
+bool XTraceWasmLoggingEnabled(i::Isolate* isolate) {
+  if (isolate->serializer_enabled()) return false;
+  constexpr uint32_t kXTraceEmbedderDataSlot = 3;
+  constexpr uintptr_t kXTraceEmbedderDataMarker = 0x5854524143450ULL;
+  if (!isolate->event_logger() ||
+      isolate->GetData(kXTraceEmbedderDataSlot) !=
+          reinterpret_cast<void*>(kXTraceEmbedderDataMarker)) {
+    return false;
+  }
+  return true;
+}
+
+void XTraceWasmBoundary(i::Isolate* isolate, const char* api,
+                        const v8::FunctionCallbackInfo<v8::Value>& info) {
+  if (!XTraceWasmLoggingEnabled(isolate)) return;
+  size_t bytes = 0;
+  if (info.Length() > 0) {
+    if (info[0]->IsArrayBuffer()) {
+      bytes = info[0].As<v8::ArrayBuffer>()->ByteLength();
+    } else if (info[0]->IsArrayBufferView()) {
+      bytes = info[0].As<v8::ArrayBufferView>()->ByteLength();
+    }
+  }
+  std::string args_json = "[{\"argc\":";
+  args_json.append(std::to_string(info.Length()));
+  args_json.append(",\"bytes\":");
+  args_json.append(std::to_string(bytes));
+  args_json.append("}]");
+  std::string event = "xtrace:vmp-runtime:";
+  event.append(api);
+  event.push_back(':');
+  event.append(args_json);
+  isolate->event_logger()(event.c_str(), v8::LogEventStatus::kLog);
+}
