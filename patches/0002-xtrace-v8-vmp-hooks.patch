 #include "src/objects/objects-inl.h"
+#include "src/objects/ordered-hash-table.h"
 
 namespace v8 {
 namespace internal {
 
+namespace {
+
+bool XTraceCollectionLoggingEnabled(Isolate* isolate) {
+  if (isolate->serializer_enabled()) return false;
+
+  constexpr uint32_t kXTraceEmbedderDataSlot = 3;
+  constexpr uintptr_t kXTraceEmbedderDataMarker = 0x5854524143450ULL;
+  return isolate->event_logger() &&
+         isolate->GetData(kXTraceEmbedderDataSlot) ==
+             reinterpret_cast<void*>(kXTraceEmbedderDataMarker);
+}
+
+std::string XTraceCollectionQuoteJson(const std::string& value) {
+  std::string quoted = "\"";
+  for (char c : value) {
+    switch (c) {
+      case '"':
+        quoted.append("\\\"");
+        break;
+      case '\\':
+        quoted.append("\\\\");
+        break;
+      case '\n':
+        quoted.append("\\n");
+        break;
+      case '\r':
+        quoted.append("\\r");
+        break;
+      case '\t':
+        quoted.append("\\t");
+        break;
+      default:
+        if (static_cast<unsigned char>(c) < 0x20) {
+          quoted.append(" ");
+        } else {
+          quoted.push_back(c);
+        }
+    }
+  }
+  quoted.push_back('"');
+  return quoted;
+}
+
+void XTraceCollectionAppendFieldPrefix(std::string& args,
+                                       bool* has_field,
+                                       const char* field_name) {
+  if (*has_field) args.push_back(',');
+  args.push_back('"');
+  args.append(field_name);
+  args.append("\":");
+  *has_field = true;
+}
+
+std::string XTraceCollectionValueRef(Isolate* isolate,
+                                     DirectHandle<Object> value) {
+  if (IsJSReceiver(*value)) {
+    return std::string("object:") +
+           std::to_string(Object::GetOrCreateHash(*value, isolate).value());
+  }
+  if (IsUndefined(*value)) return "undefined";
+  if (IsNull(*value)) return "null";
+  return "other";
+}
+
+void XTraceCollectionAppendValueRefJson(Isolate* isolate,
+                                        std::string& args,
+                                        bool* has_field,
+                                        const char* field_name,
+                                        DirectHandle<Object> value) {
+  XTraceCollectionAppendFieldPrefix(args, has_field, field_name);
+  args.append(XTraceCollectionQuoteJson(
+      XTraceCollectionValueRef(isolate, value)));
+}
+
+void XTraceCollectionAppendObjectIdJson(Isolate* isolate,
+                                        std::string& args,
+                                        bool* has_field,
+                                        const char* field_name,
+                                        DirectHandle<Object> value) {
+  XTraceCollectionAppendFieldPrefix(args, has_field, field_name);
+  if (!IsJSReceiver(*value)) {
+    args.append("null");
+    return;
+  }
+  args.append(
+      std::to_string(Object::GetOrCreateHash(*value, isolate).value()));
+}
+
+void XTraceCollectionAppendStringJson(std::string& args,
+                                      bool* has_field,
+                                      const char* field_name,
+                                      const char* value) {
+  XTraceCollectionAppendFieldPrefix(args, has_field, field_name);
+  args.append(XTraceCollectionQuoteJson(value));
+}
+
+void XTraceCollectionAppendIntJson(std::string& args,
+                                   bool* has_field,
+                                   const char* field_name,
+                                   int value) {
+  XTraceCollectionAppendFieldPrefix(args, has_field, field_name);
+  args.append(std::to_string(value));
+}
+
+void LogXTraceCollectionClear(Isolate* isolate,
+                              const char* api,
+                              DirectHandle<Object> collection,
+                              int size_before) {
+  if (!XTraceCollectionLoggingEnabled(isolate)) return;
+
+  bool has_field = false;
+  std::string args = "[{";
+  XTraceCollectionAppendValueRefJson(isolate, args, &has_field,
+                                     "collection_ref", collection);
+  XTraceCollectionAppendObjectIdJson(isolate, args, &has_field,
+                                     "collection_id", collection);
+  XTraceCollectionAppendStringJson(args, &has_field, "operation", "clear");
+  XTraceCollectionAppendIntJson(args, &has_field, "size_before", size_before);
+  DirectHandle<Object> undefined_value = isolate->factory()->undefined_value();
+  XTraceCollectionAppendValueRefJson(isolate, args, &has_field, "result_ref",
+                                     undefined_value);
+  args.append("}]");
+
+  std::string event = "xtrace:vmp-runtime:";
+  event.append(api);
+  event.push_back(':');
+  event.append(args);
+  isolate->event_logger()(event.c_str(), v8::LogEventStatus::kLog);
+}
+
