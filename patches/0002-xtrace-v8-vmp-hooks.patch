+void AppendXTraceVmpStackJson(Isolate* isolate,
+                              std::string& args,
+                              bool* has_field) {
+  AppendFieldPrefix(args, has_field, "js_stack");
+  args.push_back('[');
+  int frame_index = 0;
+  JavaScriptStackFrameIterator it(isolate);
+  for (; !it.done() && frame_index < kXTraceVmpStackFrameLimit;
+       it.Advance(), ++frame_index) {
+    if (frame_index > 0) args.push_back(',');
+    AppendXTraceVmpStackFrameJson(isolate, args, it.frame(), frame_index);
+  }
+  args.push_back(']');
+  AppendFieldPrefix(args, has_field, "js_stack_truncated");
+  args.append(it.done() ? "false" : "true");
+}
