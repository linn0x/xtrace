+DirectHandle<Object> XTraceDispatchRegisterSource(
+    Isolate* isolate,
+    DirectHandle<Object> arguments_or_first_arg,
+    DirectHandle<Object> second_arg,
+    DirectHandle<Object> explicit_count) {
+  if (XTraceIsPresentValue(second_arg)) {
+    return second_arg;
