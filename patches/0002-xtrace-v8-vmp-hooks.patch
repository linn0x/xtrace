+                             DirectHandle<String> value) {
+  const uint32_t original_length = value->length();
+  std::unique_ptr<char[]> captured = value->ToCString();
+  event.append("\"");
+  event.append(prefix);
+  event.append("\":");
+  event.append(XTraceQuoteJson(captured.get()));
+  event.append(",\"");
+  event.append(prefix);
+  event.append("_length\":");
+  event.append(std::to_string(original_length));
+}
