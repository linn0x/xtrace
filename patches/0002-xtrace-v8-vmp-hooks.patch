+void AppendXTraceVmpDispatchLightProvenanceJson(Isolate* isolate,
+                                                std::string& args,
+                                                bool* has_field) {
+  std::optional<int> script_id;
+  std::optional<int> function_start_position;
+  std::optional<int> source_position;
+  std::optional<int> code_offset;
+
+  JavaScriptStackFrameIterator it(isolate);
+  if (!it.done()) {
+    FrameSummaries summaries = it.frame()->Summarize(AllowAllocation::kNo);
+    if (summaries.size() > 0) {
+      FrameSummary summary = summaries.frames.back();
+      source_position = summary.SourcePosition();
+      code_offset = summary.code_offset();
+      if (summary.IsJavaScript()) {
+        function_start_position =
+            summary.AsJavaScript().function()->shared()->StartPosition();
+      }
+      DirectHandle<Object> script_object = summary.script();
+      if (IsScript(*script_object)) {
+        script_id = Cast<Script>(script_object)->id();
+      }
+    }
+  }
+
+  AppendStringRefJson(args, has_field, "callsite_mode", "dispatch_light");
+  AppendFieldPrefix(args, has_field, "callsite_function");
+  args.append("null");
+  AppendFieldPrefix(args, has_field, "callsite_script");
+  args.append("null");
+  AppendFieldPrefix(args, has_field, "callsite_line");
+  args.append("null");
+  AppendFieldPrefix(args, has_field, "callsite_column");
+  args.append("null");
+  AppendNullableIntJson(args, has_field, "callsite_source_position",
+                        source_position);
+  AppendNullableIntJson(args, has_field, "callsite_code_offset", code_offset);
+  AppendNullableIntJson(args, has_field, "callsite_script_id", script_id);
+  AppendNullableIntJson(args, has_field, "callsite_function_start_position",
+                        function_start_position);
+
+  AppendFieldPrefix(args, has_field, "js_stack");
+  args.append("[{\"index\":0,\"function\":null,\"script\":null,"
+              "\"line\":null,\"column\":null,\"source_position\":");
+  if (source_position.has_value()) {
+    args.append(std::to_string(source_position.value()));
+  } else {
+    args.append("null");
+  }
+  args.append(",\"code_offset\":");
+  if (code_offset.has_value()) {
+    args.append(std::to_string(code_offset.value()));
+  } else {
+    args.append("null");
+  }
+  args.append(",\"script_id\":");
+  if (script_id.has_value()) {
+    args.append(std::to_string(script_id.value()));
+  } else {
+    args.append("null");
+  }
+  args.append(",\"function_start_position\":");
+  if (function_start_position.has_value()) {
+    args.append(std::to_string(function_start_position.value()));
+  } else {
+    args.append("null");
+  }
+  args.append("}]");
+  AppendFieldPrefix(args, has_field, "js_stack_truncated");
+  args.append("true");
+}
