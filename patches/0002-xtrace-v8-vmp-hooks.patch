+void AppendDynamicDispatchVmpRefsJson(Isolate* isolate,
+                                      std::string& args,
+                                      bool* has_field,
+                                      DirectHandle<Object> target,
+                                      DirectHandle<Object> state,
+                                      DirectHandle<Object> arguments_or_first_arg,
+                                      DirectHandle<Object> second_arg,
+                                      DirectHandle<Object> explicit_count) {
+  DirectHandle<Object> state_object =
+      XTraceDispatchStateObject(state, arguments_or_first_arg);
+  AppendObjectIdJson(isolate, args, has_field, "state_object_id",
+                     state_object);
+  DirectHandle<Object> register_source =
+      XTraceDispatchRegisterSource(isolate, arguments_or_first_arg, second_arg,
+                                   explicit_count);
+  const std::string state_ref = XTraceCompactRef(isolate, state_object);
+  const std::string target_ref = XTraceCompactRef(isolate, target);
+  const std::string register_source_ref =
+      XTraceCompactRef(isolate, register_source);
+  AppendStringRefJson(args, has_field, "state_ref", state_ref);
+  AppendStringRefJson(args, has_field, "target_ref", target_ref);
+  AppendStringRefJson(args, has_field, "register_source_ref",
+                      register_source_ref);
+  AppendStringRefJson(args, has_field, "register_ref",
+                      "register:" + state_ref + "/" + register_source_ref);
+  if (XTraceIsTrackableValueRef(XTraceValueRef(isolate, register_source))) {
+    AppendStringRefJson(args, has_field, "handler_arg_ref",
+                        "handler_arg:" + target_ref + "/" +
+                            register_source_ref);
+  }
+  AppendStringRefJson(args, has_field, "handler_return_ref",
+                      "handler_return:" + target_ref + "/" +
+                          register_source_ref);
+}
