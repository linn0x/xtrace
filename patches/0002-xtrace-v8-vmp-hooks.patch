+std::string XTraceStableStringRef(DirectHandle<String> value) {
+  std::unique_ptr<char[]> captured = value->ToCString();
+  uint64_t hash = 1469598103934665603ULL;
+  for (const unsigned char* cursor =
+           reinterpret_cast<const unsigned char*>(captured.get());
+       *cursor != '\0'; ++cursor) {
+    hash ^= *cursor;
+    hash *= 1099511628211ULL;
+  }
+  return std::string("string_ref:fnv1a64:") + std::to_string(hash) +
+         ":length:" + std::to_string(value->length());
+}
+
+std::string XTraceValueRef(Isolate* isolate, DirectHandle<Object> value) {
+  if (IsJSReceiver(*value)) {
+    return std::string("object:") +
+           std::to_string(Object::GetOrCreateHash(*value, isolate).value());
+  }
+  if (IsUndefined(*value)) return "undefined";
+  if (IsNull(*value)) return "null";
+  if (IsTrue(*value)) return "boolean:true";
+  if (IsFalse(*value)) return "boolean:false";
+  if (IsNumber(*value)) {
+    const double number = Object::NumberValue(*value);
+    if (!std::isfinite(number)) return "number:nonfinite";
+    return std::string("number:") + std::to_string(number);
+  }
+  if (IsBigInt(*value)) {
+    bool lossless = false;
+    const int64_t signed_value = Cast<BigInt>(*value)->AsInt64(&lossless);
+    if (lossless) {
+      return std::string("bigint:int64:") + std::to_string(signed_value);
+    }
+    const uint64_t unsigned_value = Cast<BigInt>(*value)->AsUint64(&lossless);
+    if (lossless) {
+      return std::string("bigint:uint64:") + std::to_string(unsigned_value);
+    }
+    return "bigint";
+  }
+  if (IsString(*value)) {
+    return XTraceStableStringRef(Cast<String>(value));
+  }
+  return XTraceObjectType(value);
+}
