+
+void XTraceDefinePropertiesAppendDescriptorRefsJson(
+    Isolate* isolate,
+    std::string& args,
+    bool* has_field,
+    const char* field_name,
+    std::vector<PropertyDescriptor>& descriptors,
+    size_t descriptor_count,
+    char slot) {
+  XTraceDefinePropertiesAppendFieldPrefix(args, has_field, field_name);
+  args.push_back('[');
+  for (size_t i = 0; i < descriptor_count; ++i) {
+    if (i > 0) args.push_back(',');
+    PropertyDescriptor* desc = &descriptors[i];
+    const bool has_value = slot == 'v'   ? desc->has_value()
