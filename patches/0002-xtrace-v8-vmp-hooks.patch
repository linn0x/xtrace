+bool XTraceVmpRuntimeLoggingEnabled(Isolate* isolate) {
+  if (isolate->serializer_enabled()) return false;
+  constexpr uint32_t kXTraceEmbedderDataSlot = 3;
+  constexpr uintptr_t kXTraceEmbedderDataMarker = 0x5854524143450ULL;
+  if (!isolate->event_logger() ||
+      isolate->GetData(kXTraceEmbedderDataSlot) !=
+          reinterpret_cast<void*>(kXTraceEmbedderDataMarker)) {
+    return false;
+  }
+  return true;
+}
+
+void LogXTraceVmpRuntimeEvent(Isolate* isolate,
+                              const char* api,
+                              const std::string& args_json) {
+  if (!XTraceVmpRuntimeLoggingEnabled(isolate)) return;
+
+  std::string event = "xtrace:vmp-runtime:";
+  event.append(api);
+  event.push_back(':');
+  event.append(args_json);
+  isolate->event_logger()(event.c_str(), v8::LogEventStatus::kLog);
+}
+
+void LogXTraceVmpRuntime(Isolate* isolate,
+                         DirectHandle<String> api,
+                         const std::string& args_json) {
+  if (!XTraceVmpRuntimeLoggingEnabled(isolate)) return;
+
+  std::unique_ptr<char[]> api_text = api->ToCString();
+  LogXTraceVmpRuntimeEvent(isolate, api_text.get(), args_json);
+}
+
+const char* XTraceDispatchApiName(int code) {
+  switch (code) {
+    case 1:
+      return "Reflect.apply";
+    case 2:
+      return "Function.prototype.call";
+    case 3:
+      return "Function.prototype.apply";
+    case 4:
+      return "Reflect.construct";
+    default:
+      return nullptr;
+  }
+}
+
+const char* XTraceGeneratorState(DirectHandle<Object> value) {
+  if (!IsJSGeneratorObject(*value)) return "not_generator";
+  const int continuation = Cast<JSGeneratorObject>(*value)->continuation();
+  if (continuation == JSGeneratorObject::kGeneratorClosed) return "closed";
+  if (continuation == JSGeneratorObject::kGeneratorExecuting) {
+    return "executing";
+  }
+  return "suspended";
+}
