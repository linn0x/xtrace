+template <typename T, bool kIsFloat16>
+std::string TypedArrayElementJson(T value) {
+  if constexpr (kIsFloat16) {
+    const double number = fp16_ieee_to_fp32_value(value);
+    if (std::isnan(number)) return QuoteJson("NaN");
+    if (std::isinf(number)) {
+      return QuoteJson(number < 0 ? "-Infinity" : "Infinity");
+    }
+    return std::to_string(number);
+  } else if constexpr (std::is_floating_point_v<T>) {
+    const double number = static_cast<double>(value);
+    if (std::isnan(number)) return QuoteJson("NaN");
+    if (std::isinf(number)) {
+      return QuoteJson(number < 0 ? "-Infinity" : "Infinity");
+    }
+    return std::to_string(number);
+  } else if constexpr (std::is_same_v<T, int64_t>) {
+    return QuoteJson(std::to_string(value) + "n");
+  } else if constexpr (std::is_same_v<T, uint64_t>) {
+    return QuoteJson(std::to_string(value) + "n");
+  } else if constexpr (std::is_signed_v<T>) {
+    return std::to_string(static_cast<long long>(value));
+  } else {
+    return std::to_string(static_cast<unsigned long long>(value));
+  }
+}
+
+template <typename T, bool kIsFloat16>
+std::string TypedArrayElementRef(T value) {
+  if constexpr (kIsFloat16) {
+    const double number = fp16_ieee_to_fp32_value(value);
+    if (std::isnan(number)) return "number:NaN";
+    if (std::isinf(number)) {
+      return number < 0 ? "number:-Infinity" : "number:Infinity";
+    }
+    return std::string("number:") + std::to_string(number);
+  } else if constexpr (std::is_floating_point_v<T>) {
+    const double number = static_cast<double>(value);
+    if (std::isnan(number)) return "number:NaN";
+    if (std::isinf(number)) {
+      return number < 0 ? "number:-Infinity" : "number:Infinity";
+    }
+    return std::string("number:") + std::to_string(number);
+  } else if constexpr (std::is_same_v<T, int64_t>) {
+    return std::string("bigint:int64:") + std::to_string(value);
+  } else if constexpr (std::is_same_v<T, uint64_t>) {
+    return std::string("bigint:uint64:") + std::to_string(value);
+  } else if constexpr (std::is_signed_v<T>) {
+    return std::string("number:") +
+           std::to_string(static_cast<long long>(value));
+  } else {
+    return std::string("number:") +
+           std::to_string(static_cast<unsigned long long>(value));
+  }
+}
+
+void AppendTypedArrayElementsJson(Isolate* isolate,
+                                  std::string& args,
+                                  bool* has_field,
+                                  DirectHandle<Object> result,
+                                  const char* length_field,
+                                  const char* elements_field,
+                                  const char* element_refs_field,
+                                  const char* complete_field) {
+  AppendFieldPrefix(args, has_field, length_field);
+  if (!IsJSTypedArray(*result)) {
+    args.append("null");
+    AppendFieldPrefix(args, has_field, elements_field);
+    args.append("null");
+    AppendFieldPrefix(args, has_field, element_refs_field);
+    args.append("null");
+    AppendFieldPrefix(args, has_field, complete_field);
+    args.append(IsNull(*result) ? "true" : "false");
+    return;
+  }
+
+  DirectHandle<JSTypedArray> array = Cast<JSTypedArray>(result);
+  const size_t length = array->length();
+  args.append(std::to_string(length));
+
+  const bool can_read_elements =
+      !array->WasDetached() && !array->IsOutOfBounds();
+
+  AppendFieldPrefix(args, has_field, elements_field);
+  if (!can_read_elements) {
+    args.append("null");
+  } else {
+    args.push_back('[');
+    DisallowGarbageCollection no_gc;
+    switch (array->type()) {
+#define XTRACE_TYPED_ARRAY_ELEMENTS(Type, type, TYPE, ctype)                 \
+      case kExternal##Type##Array: {                                        \
+        const ctype* data = static_cast<const ctype*>(array->DataPtr());     \
+        for (size_t i = 0; i < length; i += 1) {                             \
+          if (i != 0) args.push_back(',');                                   \
+          args.append(TypedArrayElementJson<ctype,                           \
+              kExternal##Type##Array == kExternalFloat16Array>(data[i]));    \
+        }                                                                   \
+        break;                                                              \
+      }
+      TYPED_ARRAYS(XTRACE_TYPED_ARRAY_ELEMENTS)
+#undef XTRACE_TYPED_ARRAY_ELEMENTS
+    }
+    args.push_back(']');
+  }
+
+  AppendFieldPrefix(args, has_field, element_refs_field);
+  if (!can_read_elements) {
+    args.append("null");
+  } else {
+    args.push_back('[');
+    DisallowGarbageCollection no_gc;
+    switch (array->type()) {
+#define XTRACE_TYPED_ARRAY_ELEMENT_REFS(Type, type, TYPE, ctype)             \
+      case kExternal##Type##Array: {                                        \
+        const ctype* data = static_cast<const ctype*>(array->DataPtr());     \
+        for (size_t i = 0; i < length; i += 1) {                             \
+          if (i != 0) args.push_back(',');                                   \
+          args.append(QuoteJson(TypedArrayElementRef<ctype,                  \
+              kExternal##Type##Array == kExternalFloat16Array>(data[i])));   \
+        }                                                                   \
+        break;                                                              \
+      }
+      TYPED_ARRAYS(XTRACE_TYPED_ARRAY_ELEMENT_REFS)
+#undef XTRACE_TYPED_ARRAY_ELEMENT_REFS
+    }
+    args.push_back(']');
+  }
+
+  AppendFieldPrefix(args, has_field, complete_field);
+  args.append(can_read_elements ? "true" : "false");
+}
+
+void AppendObjectEntriesJson(Isolate* isolate,
+                             std::string& args,
+                             bool* has_field,
+                             DirectHandle<Object> result) {
+  bool entries_complete = true;
+  uint32_t length = 0;
+  AppendFieldPrefix(args, has_field, "result_entries");
+  if (!IsJSArray(*result)) {
+    entries_complete = false;
+    args.append("null");
+  } else {
+    DirectHandle<JSArray> result_array = Cast<JSArray>(result);
+    DirectHandle<Object> raw_length(result_array->length(), isolate);
+    entries_complete = Object::ToArrayLength(*raw_length, &length);
+    DirectHandle<FixedArrayBase> elements_base(
+        result_array->elements(), isolate);
+    if (!entries_complete || !IsFixedArray(*elements_base)) {
+      args.append("null");
+      AppendFieldPrefix(args, has_field, "result_entries_complete");
+      args.append("false");
+      return;
+    }
+    Tagged<FixedArray> elements = Cast<FixedArray>(*elements_base);
+    const uint32_t element_count = static_cast<uint32_t>(elements->length());
+    if (length > element_count) entries_complete = false;
+    const uint32_t readable_count = std::min(length, element_count);
+    args.push_back('[');
+    for (uint32_t i = 0; i < readable_count; ++i) {
+      if (i > 0) args.push_back(',');
+      Tagged<Object> raw_entry = elements->get(i);
+      if (IsTheHole(raw_entry) || !IsJSArray(raw_entry)) {
+        entries_complete = false;
+        args.append("null");
+        continue;
+      }
+
+      DirectHandle<JSArray> entry_array(Cast<JSArray>(raw_entry), isolate);
+      DirectHandle<FixedArrayBase> entry_elements_base(
+          entry_array->elements(), isolate);
+      if (!IsFixedArray(*entry_elements_base)) {
+        entries_complete = false;
+        args.append("null");
+        continue;
+      }
+      Tagged<FixedArray> entry_elements =
+          Cast<FixedArray>(*entry_elements_base);
+      if (entry_elements->length().value() < 2 ||
+          IsTheHole(entry_elements->get(0)) ||
+          IsTheHole(entry_elements->get(1))) {
+        entries_complete = false;
+        args.append("null");
+        continue;
+      }
+
+      DirectHandle<Object> key(entry_elements->get(0), isolate);
+      DirectHandle<Object> value(entry_elements->get(1), isolate);
+      args.append("{\"key\":");
+      args.append(JsonValue(key));
+      args.append(",\"key_ref\":");
+      args.append(QuoteJson(XTraceValueRef(isolate, key)));
+      args.append(",\"value\":");
+      args.append(JsonValue(value));
+      args.append(",\"value_ref\":");
+      args.append(QuoteJson(XTraceValueRef(isolate, value)));
+      args.push_back('}');
+    }
+    args.push_back(']');
+  }
+
+  AppendFieldPrefix(args, has_field, "result_entries_complete");
+  args.append(entries_complete ? "true" : "false");
+}
+
+void AppendSubjectLinkingJson(Isolate* isolate,
+                              std::string& args,
+                              bool* has_field,
+                              std::string_view shape,
+                              DirectHandle<Object> subject) {
+  if (shape == "data_view_get" || shape == "data_view_set" ||
+      shape == "data_view_get_uint32" || shape == "data_view_set_uint32") {
+    AppendDataViewLinkingJson(isolate, args, has_field, subject);
+  } else if (shape == "sequence_at" || shape == "sequence_slice" ||
+             shape == "sequence_subarray" || shape == "sequence_set" ||
+             shape == "sequence_sort" || shape == "sequence_join") {
+    if (IsJSTypedArray(*subject)) {
+      AppendTypedArrayLinkingJson(isolate, args, has_field, subject);
+    } else {
+      AppendObjectIdJson(isolate, args, has_field, "sequence_id", subject);
+    }
+  } else if (shape == "typed_array_find" ||
+             shape == "typed_array_reduce" ||
+             shape == "typed_array_filter" ||
+             shape == "typed_array_iteration") {
+    AppendTypedArrayLinkingJson(isolate, args, has_field, subject);
+  } else if (shape == "property_get" || shape == "property_has" ||
+             shape == "property_has_own" ||
+             shape == "property_delete" ||
+             shape == "property_set" ||
+             shape == "property_enumerable" ||
