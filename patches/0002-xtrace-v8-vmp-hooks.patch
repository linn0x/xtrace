+bool XTraceIsTrackableValueRef(const std::string& value_ref) {
+  return value_ref.rfind("number:", 0) == 0 && value_ref != "number:nonfinite";
+}
+
+void XTraceRememberValueSource(Isolate* isolate,
+                               DirectHandle<Object> value,
+                               const std::string& source_ref,
+                               const std::string& register_ref = "") {
+  if (source_ref.empty()) return;
+  const std::string value_ref = XTraceValueRef(isolate, value);
+  if (!XTraceIsTrackableValueRef(value_ref)) return;
+  XTraceValueSource& slot =
+      (*xtrace_value_sources)[xtrace_value_source_next %
+                              kXTraceValueSourceSlotCount];
+  slot.value_ref = value_ref;
+  slot.source_ref = source_ref;
+  slot.register_ref = register_ref;
+  xtrace_value_source_next += 1;
+}
+
+bool XTraceFindValueSource(Isolate* isolate,
+                           DirectHandle<Object> value,
+                           XTraceValueSource* output) {
+  const std::string value_ref = XTraceValueRef(isolate, value);
+  if (!XTraceIsTrackableValueRef(value_ref)) return false;
+  const size_t seen_count =
+      std::min(xtrace_value_source_next, kXTraceValueSourceSlotCount);
+  for (size_t offset = 0; offset < seen_count; offset += 1) {
+    const size_t index =
+        (xtrace_value_source_next + kXTraceValueSourceSlotCount - 1 - offset) %
+        kXTraceValueSourceSlotCount;
+    const XTraceValueSource& candidate = (*xtrace_value_sources)[index];
+    if (candidate.value_ref != value_ref || candidate.source_ref.empty()) {
+      continue;
+    }
+    *output = candidate;
+    return true;
+  }
+  return false;
+}
+
+const char* XTraceSourceFieldName(const char* field_prefix) {
+  if (std::string(field_prefix) == "left") return "left_source_ref";
+  if (std::string(field_prefix) == "right") return "right_source_ref";
+  if (std::string(field_prefix) == "x") return "x_source_ref";
+  if (std::string(field_prefix) == "y") return "y_source_ref";
+  if (std::string(field_prefix) == "value") return "value_source_ref";
+  if (std::string(field_prefix) == "result") return "result_source_ref";
+  return "source_ref";
+}
+
+const char* XTraceRegisterFieldName(const char* field_prefix) {
+  if (std::string(field_prefix) == "left") return "left_register_ref";
+  if (std::string(field_prefix) == "right") return "right_register_ref";
+  if (std::string(field_prefix) == "x") return "x_register_ref";
+  if (std::string(field_prefix) == "y") return "y_register_ref";
+  if (std::string(field_prefix) == "value") return "value_register_ref";
+  if (std::string(field_prefix) == "result") return "result_register_ref";
+  return "register_ref";
+}
+
+void XTraceRememberPendingDispatchSource(
+    int code,
+    uint64_t dispatch_id,
+    const std::string& handler_return_ref,
+    const std::string& register_ref) {
+  if (code != 4 || dispatch_id == 0 || handler_return_ref.empty()) return;
+  (*xtrace_pending_dispatch_sources)[static_cast<size_t>(code)].push_back(
+      {dispatch_id, handler_return_ref, register_ref});
+}
+
+bool XTraceTakePendingDispatchSource(int code,
+                                     XTracePendingDispatchSource* output) {
+  if (code < 1 || code > 4) return false;
+  std::vector<XTracePendingDispatchSource>& pending =
+      (*xtrace_pending_dispatch_sources)[static_cast<size_t>(code)];
+  if (pending.empty()) return false;
+  *output = std::move(pending.back());
+  pending.pop_back();
+  return true;
+}
+
+bool AppendBitwiseSourceRefJson(Isolate* isolate,
+                                std::string& args,
+                                bool* has_field,
+                                const char* field_prefix,
+                                DirectHandle<Object> value,
+                                XTraceValueSource* output = nullptr) {
+  XTraceValueSource source;
+  if (!XTraceFindValueSource(isolate, value, &source)) return false;
+  AppendStringRefJson(args, has_field, XTraceSourceFieldName(field_prefix),
+                      source.source_ref);
+  if (!source.register_ref.empty()) {
+    AppendStringRefJson(args, has_field, XTraceRegisterFieldName(field_prefix),
+                        source.register_ref);
+  }
+  if (output) *output = source;
+  return true;
+}
+
+void AppendDerivedResultSourceJson(Isolate* isolate,
+                                   std::string& args,
+                                   bool* has_field,
+                                   DirectHandle<Object> result,
+                                   const XTraceValueSource& source) {
+  if (source.source_ref.empty()) return;
+  AppendStringRefJson(args, has_field, "result_source_ref",
+                      source.source_ref);
+  if (!source.register_ref.empty()) {
+    AppendStringRefJson(args, has_field, "result_register_ref",
+                        source.register_ref);
+  }
+  XTraceRememberValueSource(isolate, result, source.source_ref,
+                            source.register_ref);
+}
+
+void AppendFunctionNameJson(Isolate* isolate,
+                            std::string& args,
+                            bool* has_field,
+                            DirectHandle<Object> value) {
+  AppendFieldPrefix(args, has_field, "target_function");
+  if (!IsJSFunction(*value)) {
+    args.append("null");
+    return;
+  }
+  Tagged<SharedFunctionInfo> shared = Cast<JSFunction>(*value)->shared();
+  Tagged<String> raw_name = shared->Name();
+  if (raw_name->length() == 0) raw_name = shared->inferred_name();
+  DirectHandle<String> name(raw_name, isolate);
+  std::unique_ptr<char[]> name_text = name->ToCString();
+  args.append(QuoteJson(name_text.get()));
+}
