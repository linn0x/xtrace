+bool IsXTraceCausalitySyncEnabled() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kXTraceCausalitySwitch)) {
+    return command_line->GetSwitchValueASCII(kXTraceCausalitySwitch) == "sync";
+  }
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  return env->GetVar(kXTraceCausalityEnv).value_or("") == "sync";
+}
+
+void AddXTraceExternalCausality(base::DictValue* event) {
+  if (!IsXTraceCausalitySyncEnabled()) {
+    return;
+  }
+  event->Set("schema_version", 2);
+  event->Set("call_id", base::Value());
+  event->Set("parent_id", base::Value());
+  event->Set("depth", 0);
+  event->Set("causality_kind", "external");
+  event->Set("duration_us", base::Value());
+}
