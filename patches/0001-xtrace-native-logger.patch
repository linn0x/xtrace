+}
+
+String XTraceCookieResultStringsJson(
+    const Vector<network::mojom::blink::CookieWithAccessResultPtr>& cookies,
+    bool values,
+    wtf_size_t max_count) {
+  StringBuilder builder;
+  builder.Append('[');
+  const wtf_size_t count = std::min(max_count, cookies.size());
+  for (wtf_size_t i = 0; i < count; ++i) {
+    if (i) {
+      builder.Append(',');
+    }
+    const String material = XTraceCookieResultMaterial(cookies[i], values);
+    builder.Append(XTraceLogger::QuoteJson(material));
+  }
+  builder.Append(']');
+  return builder.ToString();
+}
