+String XTraceIDBResultKeyRefJson(const IDBKey* key) {
+  if (!key) {
+    return "null";
+  }
+  const String key_ref_source =
+      String::Format("idb-result-key:%d:%llu", static_cast<int>(key->GetType()),
+                     static_cast<unsigned long long>(key->SizeEstimate()));
+  return XTraceLogger::StringHashRefJson(key_ref_source);
+}
+
+size_t XTraceIDBResultValueSize(const IDBAny* result) {
+  if (!result) {
+    return 0;
+  }
+  switch (result->GetType()) {
+    case IDBAny::kIDBValueType:
+      return result->Value() ? result->Value()->Data().size() : 0;
+    case IDBAny::kIDBValueArrayType: {
+      size_t total = 0;
+      for (const std::unique_ptr<IDBValue>& value : result->Values()) {
+        if (value) {
+          total += value->Data().size();
+        }
+      }
+      return total;
+    }
+    default:
+      return 0;
+  }
+}
+
