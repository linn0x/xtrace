+void XTraceV8EventLogger(const char* name, int status) {
+  if (status != v8::LogEventStatus::kLog || !name) {
+    return;
+  }
+
+  std::string_view event(name);
+  constexpr std::string_view kFingerprintPrefix = "xtrace:fingerprint:";
+  if (event.starts_with(kFingerprintPrefix)) {
+    event.remove_prefix(kFingerprintPrefix.size());
+    if (event == "Intl.DateTimeFormat.constructor" ||
+        event == "Intl.DateTimeFormat.resolvedOptions") {
+      std::string api(event);
+      XTraceLogger::LogCall("fingerprint", api.c_str(), String("[]"));
+    }
+    return;
+  }
+
+  constexpr std::string_view kVmpRuntimePrefix = "xtrace:vmp-runtime:";
+  if (event.starts_with(kVmpRuntimePrefix)) {
+    event.remove_prefix(kVmpRuntimePrefix.size());
+    size_t separator = event.find(':');
+    if (separator == std::string_view::npos) {
+      return;
+    }
+
+    std::string api(event.substr(0, separator));
+    const char* phase =
+        api.size() >= 4 && api.compare(api.size() - 4, 4, ".get") == 0
+            ? "get"
+            : "call";
+    String args_json =
+        String::FromUtf8WithLatin1Fallback(event.substr(separator + 1));
+    XTraceLogger::LogEventNoStack("reverse", phase, api.c_str(), args_json);
+    return;
+  }
+
+  constexpr std::string_view kPrefix = "xtrace:dynamic-code:";
+  if (!event.starts_with(kPrefix)) {
+    return;
+  }
+  event.remove_prefix(kPrefix.size());
+  size_t separator = event.find(':');
+  if (separator == std::string_view::npos) {
+    return;
+  }
+
+  std::string_view api = event.substr(0, separator);
+  if (api != "eval" && api != "Function") {
+    return;
+  }
+
+  event.remove_prefix(separator + 1);
+  int isolate_id = 0;
+  int script_id = v8::UnboundScript::kNoScriptId;
+  size_t script_id_separator = event.find(':');
+  if (script_id_separator != std::string_view::npos) {
+    int first_id = v8::UnboundScript::kNoScriptId;
+    if (base::StringToInt(event.substr(0, script_id_separator),
+                          &first_id)) {
+      event.remove_prefix(script_id_separator + 1);
+      size_t second_id_separator = event.find(':');
+      int second_id = v8::UnboundScript::kNoScriptId;
+      if (second_id_separator != std::string_view::npos &&
+          base::StringToInt(event.substr(0, second_id_separator),
+                            &second_id)) {
+        isolate_id = first_id;
+        script_id = second_id;
+        event.remove_prefix(second_id_separator + 1);
+      } else {
+        script_id = first_id;
+      }
+    }
+  }
+
+  String source_text = String::FromUtf8WithLatin1Fallback(event);
+  const char* compile_status = script_id > 0 ? "success" : "error";
+  std::string args_json = "[{\"source\":";
+  args_json.append(XTraceLogger::QuoteJson(source_text).Utf8());
+  args_json.append(",\"source_length\":");
+  args_json.append(base::NumberToString(source_text.length()));
+  args_json.append(",\"script_id\":");
+  args_json.append(base::NumberToString(script_id));
+  args_json.append(",\"isolate_id\":");
+  args_json.append(isolate_id > 0 ? base::NumberToString(isolate_id) : "null");
+  args_json.append(",\"compile_status\":\"");
+  args_json.append(compile_status);
+  args_json.append("\"}]");
+  XTraceLogger::LogAssetEvent(
+      "reverse", "call", api == "Function" ? "Function" : "eval",
+      String::FromUtf8(args_json),
+      "dynamic-code", String(), source_text);
+}
