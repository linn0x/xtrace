+// static
+std::string XTraceHostImpl::StampGlobalSequenceForWrite(
+    std::string event_json) {
+  if (event_json.empty() || HasTopLevelJsonKey(event_json, "global_seq")) {
+    return event_json;
+  }
+
+  const size_t object_end = event_json.find_last_not_of(" \t\r\n");
+  if (object_end == std::string::npos || event_json[object_end] != '}') {
+    return event_json;
+  }
+
+  const uint64_t global_seq =
+      g_xtrace_file_global_sequence.fetch_add(1, std::memory_order_relaxed) + 1;
+  event_json.insert(
+      object_end,
+      base::StrCat({",\"global_seq\":", base::NumberToString(global_seq)}));
+  return event_json;
+}
+
+void XTraceHostImpl::Log(const std::string& event_json) {
+  if (event_json.empty() || !EnsureFile()) {
+    return;
+  }
+
+  WriteJsonLine(trace_file_, StampGlobalSequenceForWrite(event_json),
+                "write failed");
+}
+
+void XTraceHostImpl::LogBatch(
+    const std::vector<std::string>& event_json_lines) {
+  if (event_json_lines.empty() || !EnsureFile()) {
+    return;
+  }
+
+  for (const std::string& event_json : event_json_lines) {
+    if (event_json.empty()) {
+      continue;
+    }
+    if (!WriteJsonLine(trace_file_, StampGlobalSequenceForWrite(event_json),
+                       "batch write failed")) {
+      return;
+    }
+  }
+}
+
+void XTraceHostImpl::LogAsset(const std::string& content_path,
+                              const std::string& manifest_json,
+                              const std::string& content) {
+  if (!trace_file_path_ || manifest_json.empty() || !EnsureAssetManifestFile()) {
+    return;
+  }
+
+  if (!content.empty() && IsSafeRelativeContentPath(content_path)) {
+    base::FilePath asset_path =
+        trace_file_path_->DirName().Append(base::FilePath::FromUTF8Unsafe(
+            content_path));
+    if (!base::CreateDirectory(asset_path.DirName())) {
+      DLogWriteFailureOnce("asset directory create failed");
+      return;
+    }
+    base::File asset_file(
+        asset_path, base::File::FLAG_CREATE_ALWAYS | base::File::FLAG_WRITE);
+    if (!asset_file.IsValid() ||
+        !asset_file.WriteAtCurrentPosAndCheck(base::as_byte_span(content))) {
+      DLogWriteFailureOnce("asset write failed");
+      return;
+    }
+  }
+
+  WriteJsonLine(asset_manifest_file_, manifest_json, "asset manifest write failed");
+}
+
+bool XTraceHostImpl::EnsureFile() {
+  if (!trace_file_path_) {
+    return false;
+  }
+  if (trace_file_.IsValid()) {
+    return true;
+  }
+
+  if (!base::CreateDirectory(trace_file_path_->DirName())) {
+    DLogWriteFailureOnce("create directory failed");
+    return false;
+  }
+
+  trace_file_.Initialize(*trace_file_path_, base::File::FLAG_OPEN_ALWAYS |
+                                                base::File::FLAG_APPEND);
+  if (!trace_file_.IsValid()) {
+    std::string error_details =
+        base::File::ErrorToString(trace_file_.error_details());
+    DLogWriteFailureOnce(error_details.c_str());
+    return false;
+  }
+  return true;
+}
+
+bool XTraceHostImpl::EnsureAssetManifestFile() {
+  if (!trace_file_path_) {
+    return false;
+  }
+  if (asset_manifest_file_.IsValid()) {
+    return true;
+  }
+
+  base::FilePath manifest_path = AssetManifestPathFromTracePath(*trace_file_path_);
+  if (!base::CreateDirectory(manifest_path.DirName())) {
+    DLogWriteFailureOnce("asset manifest directory create failed");
+    return false;
+  }
+
+  asset_manifest_file_.Initialize(
+      manifest_path, base::File::FLAG_OPEN_ALWAYS | base::File::FLAG_APPEND);
+  if (!asset_manifest_file_.IsValid()) {
+    std::string error_details =
+        base::File::ErrorToString(asset_manifest_file_.error_details());
+    DLogWriteFailureOnce(error_details.c_str());
+    return false;
+  }
+  return true;
+}
+
+bool XTraceHostImpl::WriteJsonLine(base::File& file,
+                                   const std::string& json,
+                                   const char* failure_reason) {
+  if (!file.WriteAtCurrentPosAndCheck(base::as_byte_span(json))) {
+    DLogWriteFailureOnce(failure_reason);
+    return false;
+  }
+
+  if (!json.empty() && json.back() != '\n') {
+    static constexpr char kNewline[] = "\n";
+    if (!file.WriteAtCurrentPosAndCheck(base::byte_span_from_cstring(kNewline))) {
+      DLogWriteFailureOnce("newline write failed");
+      return false;
+    }
+  }
+  return true;
+}
+
+void XTraceHostImpl::DLogWriteFailureOnce(const char* reason) {
+  if (logged_write_failure_ || !trace_file_path_) {
+    return;
+  }
+  logged_write_failure_ = true;
+  DLOG(WARNING) << "XTrace failed to write trace in browser process: " << reason
+                << ": " << trace_file_path_->AsUTF8Unsafe();
+}
+
+}  // namespace content
