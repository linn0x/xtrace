+// Copyright 2026 The XTrace Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in Chromium's LICENSE file.
+
+module blink.mojom;
+
+// Process-scoped trace sink used by native Blink XTrace instrumentation.
+// Renderer code sends already serialized NDJSON event lines; the browser
+// process owns the file handle so renderer sandboxing can remain enabled.
+interface XTraceHost {
+  Log(string event_json);
+  LogBatch(array<string> event_json_lines);
+  LogAsset(string content_path, string manifest_json, string content);
+};
