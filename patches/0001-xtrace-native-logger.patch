+constexpr char kEnableEnv[] = "XTRACE_ENABLE";
+constexpr char kFileEnv[] = "XTRACE_FILE";
+constexpr char kEnableSwitch[] = "xtrace-enable";
+constexpr char kFileSwitch[] = "xtrace-file";
+
+std::atomic<uint64_t> g_xtrace_file_global_sequence{0};
+
+bool HasTopLevelJsonKey(std::string_view event_json, std::string_view key) {
+  int depth = 0;
+  bool in_string = false;
+  bool escaped = false;
+  size_t string_start = 0;
+
+  for (size_t i = 0; i < event_json.size(); ++i) {
+    const char c = event_json[i];
+    if (in_string) {
+      if (escaped) {
+        escaped = false;
+        continue;
+      }
+      if (c == '\\') {
+        escaped = true;
+        continue;
+      }
+      if (c != '"') {
+        continue;
+      }
+
+      in_string = false;
+      if (depth != 1 ||
+          event_json.substr(string_start, i - string_start) != key) {
+        continue;
+      }
+
+      size_t next = i + 1;
+      while (next < event_json.size() &&
+             (event_json[next] == ' ' || event_json[next] == '\t' ||
+              event_json[next] == '\r' || event_json[next] == '\n')) {
+        ++next;
+      }
+      if (next < event_json.size() && event_json[next] == ':') {
+        return true;
+      }
+      continue;
+    }
+
+    if (c == '"') {
+      in_string = true;
+      escaped = false;
+      string_start = i + 1;
+    } else if (c == '{' || c == '[') {
+      ++depth;
+    } else if (c == '}' || c == ']') {
+      --depth;
+    }
+  }
+
+  return false;
+}
+
+std::string TraceStemFromPath(const base::FilePath& trace_file_path) {
+  return trace_file_path.BaseName().RemoveExtension().AsUTF8Unsafe();
+}
+
+base::FilePath AssetManifestPathFromTracePath(
+    const base::FilePath& trace_file_path) {
+  return trace_file_path.DirName()
+      .AppendASCII("assets")
+      .Append(base::FilePath::FromUTF8Unsafe(TraceStemFromPath(trace_file_path)))
+      .AppendASCII("manifest.ndjson");
+}
+
+bool IsSafeRelativeContentPath(const std::string& content_path) {
+  return !content_path.empty() && content_path[0] != '/' &&
+         content_path.find("..") == std::string::npos &&
+         content_path.find('\\') == std::string::npos;
+}
+
+std::optional<base::FilePath> ReadTraceFilePathFromRuntime() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kEnableSwitch)) {
+    base::FilePath trace_file = command_line->GetSwitchValuePath(kFileSwitch);
+    if (!trace_file.empty()) {
+      return trace_file;
+    }
+  }
+
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled = env->GetVar(kEnableEnv);
+  if (!enabled || *enabled != "1") {
+    return std::nullopt;
+  }
+
+  std::optional<std::string> trace_file = env->GetVar(kFileEnv);
+  if (!trace_file || trace_file->empty()) {
+    return std::nullopt;
+  }
+
+  return base::FilePath::FromUTF8Unsafe(*trace_file);
+}
