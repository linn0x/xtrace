+std::optional<base::FilePath> ReadXTraceBrowserNetworkTraceFilePath() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kXTraceEnableSwitch)) {
+    base::FilePath trace_file =
+        command_line->GetSwitchValuePath(kXTraceFileSwitch);
+    if (!trace_file.empty()) {
+      return trace_file;
+    }
+  }
+
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled = env->GetVar(kXTraceEnableEnv);
+  if (!enabled || *enabled != "1") {
+    return std::nullopt;
+  }
+
+  std::optional<std::string> trace_file = env->GetVar(kXTraceFileEnv);
+  if (!trace_file || trace_file->empty()) {
+    return std::nullopt;
+  }
+  return base::FilePath::FromUTF8Unsafe(*trace_file);
+}
+
+bool IsXTraceBrowserNetworkEnabled() {
+  return ReadXTraceBrowserNetworkTraceFilePath().has_value();
+}
+
+uint64_t ReadXTraceBrowserNetworkUInt64(const char* switch_name,
+                                        const char* env_name,
+                                        uint64_t default_value) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  std::string value;
+  if (command_line->HasSwitch(switch_name)) {
+    value = command_line->GetSwitchValueASCII(switch_name);
+  } else {
+    std::unique_ptr<base::Environment> env = base::Environment::Create();
+    std::string env_name_string(env_name);
+    std::optional<std::string> env_value = env->GetVar(env_name_string);
+    if (env_value) {
+      value = *env_value;
+    }
+  }
+
+  uint64_t parsed = 0;
+  if (!value.empty() && base::StringToUint64(value, &parsed)) {
+    return parsed;
+  }
+  return default_value;
+}
+
+base::DictValue CreateXTraceTruncationItem(std::string_view path,
+                                           uint64_t original_size,
+                                           uint64_t preview_size,
+                                           std::string_view hash,
+                                           std::string_view preview) {
+  base::DictValue item;
+  item.Set("path", std::string(path));
+  item.Set("original_size", static_cast<double>(original_size));
+  item.Set("preview_size", static_cast<double>(preview_size));
+  item.Set("hash", std::string(hash));
+  item.Set("preview", std::string(preview));
+  return item;
+}
+
+void AppendXTraceTruncationItem(base::ListValue* truncation_items,
+                                base::DictValue* top_level_truncation,
+                                bool* has_top_level_truncation,
+                                std::string_view path,
+                                uint64_t original_size,
+                                uint64_t preview_size,
+                                std::string_view hash,
+                                std::string_view preview) {
+  if (!*has_top_level_truncation) {
+    *top_level_truncation = CreateXTraceTruncationItem(
+        path, original_size, preview_size, hash, preview);
+    *has_top_level_truncation = true;
+  }
+  truncation_items->Append(CreateXTraceTruncationItem(
+      path, original_size, preview_size, hash, preview));
+}
+
+base::ListValue CreateXTraceRequestHeadersJson(
+    const net::HttpRequestHeaders& request_headers,
+    uint64_t max_header_value_bytes,
+    bool* truncated,
+    base::ListValue* truncation_items,
+    base::DictValue* top_level_truncation,
+    bool* has_top_level_truncation) {
+  base::ListValue headers;
+  size_t header_index = 0;
+  for (net::HttpRequestHeaders::Iterator it(request_headers); it.GetNext();) {
+    base::DictValue header;
+    std::string name(it.name());
+    std::string value(it.value());
+    std::string captured_value(value);
+    header.Set("name", name);
+    header.Set("name_length", static_cast<int>(name.size()));
+    header.Set("value_length", static_cast<int>(value.size()));
+    if (max_header_value_bytes > 0 &&
+        value.size() > max_header_value_bytes) {
+      captured_value = value.substr(0, max_header_value_bytes);
+      const std::string value_hash =
+          base::HexEncodeLower(crypto::SHA256HashString(value));
+      header.Set("value_sha256", value_hash);
+      header.Set("value_truncated", true);
+      *truncated = true;
+      AppendXTraceTruncationItem(
+          truncation_items, top_level_truncation, has_top_level_truncation,
+          base::StrCat({"args[0].headers[", base::NumberToString(header_index),
+                        "].value"}),
+          value.size(), captured_value.size(), value_hash, captured_value);
+    }
+    header.Set("value", captured_value);
+    headers.Append(std::move(header));
+    ++header_index;
+  }
+  return headers;
+}
+
+base::ListValue CreateXTraceResponseHeadersJson(
+    const net::HttpResponseHeaders* response_headers,
+    uint64_t max_header_value_bytes,
+    bool* truncated,
+    base::ListValue* truncation_items,
+    base::DictValue* top_level_truncation,
+    bool* has_top_level_truncation) {
+  base::ListValue headers;
+  if (!response_headers) {
+    return headers;
+  }
+
+  size_t header_iterator = 0;
+  size_t header_index = 0;
+  std::string name;
+  std::string value;
+  while (response_headers->EnumerateHeaderLines(&header_iterator, &name,
+                                                &value)) {
+    base::DictValue header;
+    std::string captured_value(value);
+    header.Set("name", name);
+    header.Set("name_length", static_cast<int>(name.size()));
+    header.Set("value_length", static_cast<int>(value.size()));
+    if (max_header_value_bytes > 0 &&
+        value.size() > max_header_value_bytes) {
+      captured_value = value.substr(0, max_header_value_bytes);
+      const std::string value_hash =
+          base::HexEncodeLower(crypto::SHA256HashString(value));
+      header.Set("value_sha256", value_hash);
+      header.Set("value_truncated", true);
+      *truncated = true;
+      AppendXTraceTruncationItem(
+          truncation_items, top_level_truncation, has_top_level_truncation,
+          base::StrCat({"args[0].response_headers[",
+                        base::NumberToString(header_index), "].value"}),
+          value.size(), captured_value.size(), value_hash, captured_value);
+    }
+    header.Set("value", captured_value);
+    headers.Append(std::move(header));
+    ++header_index;
+  }
+  return headers;
+}
+
+base::DictValue CreateXTraceUploadBodyJson(
+    const network::ResourceRequestBody* request_body,
+    uint64_t max_body_bytes,
+    bool* truncated,
+    base::ListValue* truncation_items,
+    base::DictValue* top_level_truncation,
+    bool* has_top_level_truncation) {
+  base::DictValue upload;
+  if (!request_body) {
+    upload.Set("element_count", 0);
+    upload.Set("total_bytes", 0.0);
+    upload.Set("in_memory_bytes", 0.0);
+    upload.Set("has_file", false);
+    upload.Set("has_blob", false);
+    upload.Set("has_data_pipe", false);
+    upload.Set("has_chunked_data_pipe", false);
+    upload.Set("truncated", false);
+    return upload;
+  }
+
+  const std::vector<network::DataElement>* elements = request_body->elements();
+  uint64_t total_bytes = 0;
+  uint64_t in_memory_bytes = 0;
+  bool has_file = false;
+  bool has_data_pipe = false;
+  bool has_chunked_data_pipe = false;
+  bool has_unknown_size = false;
+  std::string body_bytes;
+
+  for (const network::DataElement& element : *elements) {
+    switch (element.type()) {
+      case network::DataElement::Tag::kBytes: {
+        const std::string_view bytes =
+            element.As<network::DataElementBytes>().AsStringView();
+        total_bytes += bytes.size();
+        in_memory_bytes += bytes.size();
+        body_bytes.append(bytes);
+        break;
+      }
+      case network::DataElement::Tag::kFile: {
+        const network::DataElementFile& file =
+            element.As<network::DataElementFile>();
+        total_bytes += file.length();
+        has_file = true;
+        break;
+      }
+      case network::DataElement::Tag::kDataPipe:
+        has_data_pipe = true;
+        has_unknown_size = true;
+        break;
+      case network::DataElement::Tag::kChunkedDataPipe:
+        has_chunked_data_pipe = true;
+        has_unknown_size = true;
+        break;
+    }
+  }
+
+  upload.Set("element_count", static_cast<int>(elements->size()));
+  upload.Set("total_bytes", static_cast<double>(total_bytes));
+  upload.Set("in_memory_bytes", static_cast<double>(in_memory_bytes));
+  upload.Set("has_file", has_file);
+  upload.Set("has_blob", has_data_pipe);
+  upload.Set("has_data_pipe", has_data_pipe);
+  upload.Set("has_chunked_data_pipe", has_chunked_data_pipe);
+  upload.Set("has_unknown_size", has_unknown_size);
+  if (!body_bytes.empty()) {
+    std::string captured_body(body_bytes);
+    const std::string body_hash =
+        base::HexEncodeLower(crypto::SHA256HashString(body_bytes));
+    bool body_truncated = false;
+    if (max_body_bytes > 0 && body_bytes.size() > max_body_bytes) {
+      captured_body = body_bytes.substr(0, max_body_bytes);
+      body_truncated = true;
+      *truncated = true;
+      AppendXTraceTruncationItem(
+          truncation_items, top_level_truncation, has_top_level_truncation,
+          "args[0].upload_body.body_hex", body_bytes.size(),
+          captured_body.size(), body_hash,
+          base::HexEncode(base::as_byte_span(captured_body)));
+    }
+    upload.Set("body_hex", base::HexEncode(base::as_byte_span(captured_body)));
+    upload.Set("body_sha256", body_hash);
+    upload.Set("truncated", body_truncated);
+  } else {
+    upload.Set("truncated", false);
+  }
+  return upload;
+}
+
+std::string CreateXTraceNetworkCorrelationKey(std::string_view method,
+                                              const GURL& url) {
+  std::string material =
+      base::ToUpperASCII(std::string(method)) + "\n" + url.spec();
+  return "sha1:" + base::HexEncode(base::SHA1HashString(material));
+}
+
+std::string CreateXTraceBrowserNetworkEventJson(
+    std::string_view api,
+    const network::ResourceRequest& request,
+    const GURL& url,
+    std::string_view method) {
+  const int seq = g_xtrace_browser_network_sequence.GetNext() + 1;
+  const base::ProcessId pid = base::GetCurrentProcId();
+  const int64_t wall_time_us = base::Time::Now().ToInternalValue();
+  const int64_t mono_time_us =
+      base::TimeTicks::Now().since_origin().InMicroseconds();
+  bool truncated = false;
+  bool has_top_level_truncation = false;
+  base::DictValue top_level_truncation;
+  base::ListValue truncation_items;
+  const uint64_t max_body_bytes = ReadXTraceBrowserNetworkUInt64(
+      kXTraceMaxBodyBytesSwitch, kXTraceMaxBodyBytesEnv, 0);
+  const uint64_t max_header_value_bytes = ReadXTraceBrowserNetworkUInt64(
+      kXTraceMaxHeaderValueBytesSwitch, kXTraceMaxHeaderValueBytesEnv, 0);
+
+  base::DictValue arg;
+  arg.Set("url", url.spec());
+  arg.Set("method", std::string(method));
+  arg.Set("network_correlation_key",
+          CreateXTraceNetworkCorrelationKey(method, url));
+  arg.Set("request_initiator",
+          request.request_initiator ? request.request_initiator->Serialize()
+                                    : std::string());
+  arg.Set("referrer", request.referrer.spec());
+  arg.Set("resource_type", request.resource_type);
+  arg.Set("destination", static_cast<int>(request.destination));
+  arg.Set("mode", static_cast<int>(request.mode));
+  arg.Set("credentials_mode", static_cast<int>(request.credentials_mode));
+  arg.Set("redirect_mode", static_cast<int>(request.redirect_mode));
+  arg.Set("load_flags", request.load_flags);
+  arg.Set("is_fetch_like_api", request.is_fetch_like_api);
+  arg.Set("is_fetch_later_api", request.is_fetch_later_api);
+  arg.Set("keepalive", request.keepalive);
+  arg.Set("has_user_gesture", request.has_user_gesture);
+  arg.Set("originated_from_service_worker",
+          request.originated_from_service_worker);
+  arg.Set("headers",
+          CreateXTraceRequestHeadersJson(
+              request.headers, max_header_value_bytes, &truncated,
+              &truncation_items, &top_level_truncation,
+              &has_top_level_truncation));
+  const bool has_request_body = request.request_body != nullptr;
+  arg.Set("has_request_body", has_request_body);
+  if (has_request_body) {
+    arg.Set("upload_body",
+            CreateXTraceUploadBodyJson(
+                request.request_body.get(), max_body_bytes, &truncated,
+                &truncation_items, &top_level_truncation,
+                &has_top_level_truncation));
+  }
+
+  base::ListValue args;
+  args.Append(std::move(arg));
+
+  base::DictValue event;
+  event.Set("schema_version", 1);
+  event.Set("event_id", base::StrCat({"browser-network:", base::NumberToString(pid),
+                                      ":", base::NumberToString(seq)}));
+  event.Set("session_id",
+            base::StrCat({"browser-network:", base::NumberToString(pid)}));
+  event.Set("seq", seq);
+  event.Set("session_seq", seq);
+  event.Set("t", api == "BrowserNetwork.redirect" ? "redirect" : "call");
+  event.Set("ts", static_cast<double>(wall_time_us));
+  event.Set("wall_time_us", static_cast<double>(wall_time_us));
+  event.Set("mono_time_us", static_cast<double>(mono_time_us));
+  event.Set("category", "network");
+  event.Set("phase", api == "BrowserNetwork.redirect" ? "lifecycle" : "call");
+  event.Set("pid", pid);
+  event.Set("tid", 0);
+  event.Set("api", std::string(api));
+  event.Set("args", std::move(args));
+  event.Set("stack", base::ListValue());
+  event.Set("frame_url", request.referrer.spec());
+  event.Set("origin", request.request_initiator
+                          ? request.request_initiator->Serialize()
+                          : std::string());
+  event.Set("result", base::Value());
+  event.Set("error", base::Value());
+  event.Set("truncated", truncated);
+  if (has_top_level_truncation) {
+    top_level_truncation.Set("items", std::move(truncation_items));
+    event.Set("truncation", std::move(top_level_truncation));
+  }
+
+  std::string json;
+  base::JSONWriter::Write(event, &json);
+  return json;
+}
