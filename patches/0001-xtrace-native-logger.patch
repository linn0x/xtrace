+class XTraceBrowserNetworkProxyingURLLoaderFactory
+    : public network::SelfDeletingURLLoaderFactory {
+ public:
+  XTraceBrowserNetworkProxyingURLLoaderFactory(
+      mojo::PendingReceiver<network::mojom::URLLoaderFactory> loader_receiver,
+      mojo::PendingRemote<network::mojom::URLLoaderFactory>
+          target_factory_remote,
+      base::SelfDeletingPassKey pass_key)
+      : network::SelfDeletingURLLoaderFactory(std::move(loader_receiver),
+                                              pass_key) {
+    target_factory_.Bind(std::move(target_factory_remote));
+    target_factory_.set_disconnect_handler(base::BindOnce(
+        &XTraceBrowserNetworkProxyingURLLoaderFactory::OnTargetFactoryError,
+        base::Unretained(this)));
+  }
+  XTraceBrowserNetworkProxyingURLLoaderFactory(
+      const XTraceBrowserNetworkProxyingURLLoaderFactory&) = delete;
+  XTraceBrowserNetworkProxyingURLLoaderFactory& operator=(
+      const XTraceBrowserNetworkProxyingURLLoaderFactory&) = delete;
+
+  static void MaybeProxyRequest(
+      content::BrowserContext* browser_context,
+      network::URLLoaderFactoryBuilder& factory_builder) {
+    if (!browser_context || !IsXTraceBrowserNetworkEnabled()) {
+      return;
+    }
+
+    auto [receiver, remote] = factory_builder.Append();
+    base::MakeSelfDeleting<XTraceBrowserNetworkProxyingURLLoaderFactory>(
+        std::move(receiver), std::move(remote));
+  }
+
+  void CreateLoaderAndStart(
+      mojo::PendingReceiver<network::mojom::URLLoader> loader_receiver,
+      int32_t request_id,
+      uint32_t options,
+      const network::ResourceRequest& request,
+      mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+      const net::MutableNetworkTrafficAnnotationTag& traffic_annotation)
+      override {
+    LogXTraceBrowserNetworkEvent(CreateXTraceBrowserNetworkEventJson(
+        "BrowserNetwork.request", request, request.url, request.method));
+    mojo::PendingRemote<network::mojom::URLLoaderClient> wrapped_client =
+        CreateXTraceBrowserNetworkURLLoaderClientRemote(request,
+                                                        std::move(client));
+    target_factory_->CreateLoaderAndStart(std::move(loader_receiver),
+                                          request_id, options, request,
+                                          std::move(wrapped_client),
+                                          traffic_annotation);
+  }
+
+ private:
+  ~XTraceBrowserNetworkProxyingURLLoaderFactory() override = default;
+
+  void OnTargetFactoryError() { DisconnectReceiversAndDestroy(); }
+
+  mojo::Remote<network::mojom::URLLoaderFactory> target_factory_;
+};
