+  event.Set("mono_time_us", static_cast<double>(mono_time_us));
+  event.Set("category", "network");
+  event.Set("phase", "return");
+  event.Set("pid", pid);
+  event.Set("tid", 0);
+  event.Set("api", "BrowserNetwork.response");
+  event.Set("args", std::move(args));
+  event.Set("stack", base::ListValue());
+  event.Set("frame_url", request.referrer.spec());
+  event.Set("origin", request.request_initiator
+                          ? request.request_initiator->Serialize()
+                          : std::string());
+  event.Set("result", base::Value());
+  event.Set("error", base::Value());
+  event.Set("truncated", truncated);
+  if (has_top_level_truncation) {
+    top_level_truncation.Set("items", std::move(truncation_items));
+    event.Set("truncation", std::move(top_level_truncation));
+  }
+
+  std::string json;
+  base::JSONWriter::Write(event, &json);
+  return json;
+}
+
+std::string CreateXTraceBrowserNetworkCompleteEventJson(
+    const network::ResourceRequest& request,
+    const network::URLLoaderCompletionStatus& completion_status) {
+  const int seq = g_xtrace_browser_network_sequence.GetNext() + 1;
+  const base::ProcessId pid = base::GetCurrentProcId();
+  const int64_t wall_time_us = base::Time::Now().ToInternalValue();
+  const int64_t mono_time_us =
+      base::TimeTicks::Now().since_origin().InMicroseconds();
+  const int64_t completion_time_us =
+      completion_status.completion_time.is_null()
+          ? 0
+          : completion_status.completion_time.since_origin().InMicroseconds();
+
+  base::DictValue arg;
+  arg.Set("url", request.url.spec());
+  arg.Set("method", request.method);
+  arg.Set("network_correlation_key",
+          CreateXTraceNetworkCorrelationKey(request.method, request.url));
+  arg.Set("request_initiator",
+          request.request_initiator ? request.request_initiator->Serialize()
+                                    : std::string());
+  arg.Set("referrer", request.referrer.spec());
+  arg.Set("error_code", completion_status.error_code);
+  arg.Set("extended_error_code", completion_status.extended_error_code);
+  arg.Set("exists_in_cache", completion_status.exists_in_cache);
+  arg.Set("completion_time_mono_us",
+          static_cast<double>(completion_time_us));
+  arg.Set("encoded_data_length",
+          static_cast<double>(completion_status.encoded_data_length));
+  arg.Set("encoded_body_length",
+          static_cast<double>(completion_status.encoded_body_length));
+  arg.Set("decoded_body_length",
+          static_cast<double>(completion_status.decoded_body_length));
+  arg.Set("trust_token_operation_status",
+          static_cast<int>(completion_status.trust_token_operation_status));
+  arg.Set("has_ssl_info", completion_status.ssl_info.has_value());
+  arg.Set("should_report_orb_blocking",
+          completion_status.should_report_orb_blocking);
+  arg.Set("resolve_error_info_error",
+          completion_status.resolve_error_info.error);
+  arg.Set("resolve_error_info_is_secure_network_error",
+          completion_status.resolve_error_info.is_secure_network_error);
+  arg.Set("should_collapse_initiator",
+          completion_status.should_collapse_initiator);
+
+  if (completion_status.cors_error_status) {
+    const network::CorsErrorStatus& cors_error =
+        *completion_status.cors_error_status;
+    base::DictValue cors;
+    cors.Set("cors_error", static_cast<int>(cors_error.cors_error));
+    cors.Set("failed_parameter", cors_error.failed_parameter);
+    cors.Set("resource_address_space",
+             static_cast<int>(cors_error.resource_address_space));
+    cors.Set("inconsistent_address_space",
+             static_cast<int>(cors_error.inconsistent_address_space));
+    cors.Set("has_authorization_covered_by_wildcard_on_preflight",
+             cors_error.has_authorization_covered_by_wildcard_on_preflight);
+    cors.Set("issue_id", cors_error.issue_id.ToString());
+    arg.Set("cors_error_status", std::move(cors));
+  } else {
+    arg.Set("cors_error_status", base::Value());
+  }
+
+  if (completion_status.blocked_by_response_reason) {
+    arg.Set("blocked_by_response_reason",
+            static_cast<int>(*completion_status.blocked_by_response_reason));
+  } else {
+    arg.Set("blocked_by_response_reason", base::Value());
+  }
+
+  base::ListValue args;
+  args.Append(std::move(arg));
+
+  base::DictValue event;
+  event.Set("schema_version", 1);
+  event.Set("event_id", base::StrCat({"browser-network:", base::NumberToString(pid),
+                                      ":", base::NumberToString(seq)}));
+  event.Set("session_id",
+            base::StrCat({"browser-network:", base::NumberToString(pid)}));
+  event.Set("seq", seq);
+  event.Set("session_seq", seq);
+  event.Set("t", "return");
+  event.Set("ts", static_cast<double>(wall_time_us));
+  event.Set("wall_time_us", static_cast<double>(wall_time_us));
+  event.Set("mono_time_us", static_cast<double>(mono_time_us));
+  event.Set("category", "network");
+  event.Set("phase", "complete");
+  event.Set("pid", pid);
+  event.Set("tid", 0);
+  event.Set("api", "BrowserNetwork.complete");
+  event.Set("args", std::move(args));
+  event.Set("stack", base::ListValue());
+  event.Set("frame_url", request.referrer.spec());
+  event.Set("origin", request.request_initiator
+                          ? request.request_initiator->Serialize()
+                          : std::string());
+  event.Set("result", base::Value());
+  if (completion_status.error_code != 0 ||
+      completion_status.extended_error_code != 0 ||
+      completion_status.cors_error_status ||
+      completion_status.blocked_by_response_reason) {
+    base::DictValue error;
+    error.Set("code", completion_status.error_code);
+    error.Set("extended_error_code",
+              completion_status.extended_error_code);
+    error.Set("resolve_error_info_error",
+              completion_status.resolve_error_info.error);
+    event.Set("error", std::move(error));
+  } else {
+    event.Set("error", base::Value());
+  }
+  event.Set("truncated", false);
+
+  std::string json;
+  base::JSONWriter::Write(event, &json);
+  return json;
+}
+
+scoped_refptr<base::SequencedTaskRunner>
+GetXTraceBrowserNetworkTaskRunner() {
+  return content::XTraceHostImpl::GetTaskRunner();
+}
+
+void WriteXTraceBrowserNetworkEvent(std::string event_json) {
+  std::optional<base::FilePath> trace_file =
+      ReadXTraceBrowserNetworkTraceFilePath();
+  if (!trace_file || event_json.empty()) {
+    return;
+  }
+  if (!base::CreateDirectory(trace_file->DirName())) {
+    return;
+  }
+  std::string stamped_event_json =
+      content::XTraceHostImpl::StampGlobalSequenceForWrite(
+          std::move(event_json));
+  stamped_event_json.push_back('\n');
+  base::AppendToFile(*trace_file, stamped_event_json);
+}
+
+void LogXTraceBrowserNetworkEvent(std::string event_json) {
+  if (event_json.empty()) {
+    return;
+  }
+  GetXTraceBrowserNetworkTaskRunner()->PostTask(
+      FROM_HERE, base::BindOnce(&WriteXTraceBrowserNetworkEvent,
+                                std::move(event_json)));
+}
+
+class XTraceBrowserNetworkThrottle final : public blink::URLLoaderThrottle {
+ public:
+  XTraceBrowserNetworkThrottle() = default;
+  ~XTraceBrowserNetworkThrottle() override = default;
+  XTraceBrowserNetworkThrottle(const XTraceBrowserNetworkThrottle&) = delete;
+  XTraceBrowserNetworkThrottle& operator=(const XTraceBrowserNetworkThrottle&) =
+      delete;
+
+  void WillStartRequest(network::ResourceRequest* request,
+                        bool* defer) override {
+    if (!request) {
+      return;
+    }
+    request_ = *request;
+    LogXTraceBrowserNetworkEvent(CreateXTraceBrowserNetworkEventJson(
+        "BrowserNetwork.request", *request, request->url, request->method));
+  }
+
+  void WillRedirectRequest(
+      net::RedirectInfo* redirect_info,
+      const network::mojom::URLResponseHead& response_head,
+      bool* defer,
+      network::HttpRequestHeadersUpdateParams* headers_update_params) override {
+    if (!redirect_info || !request_) {
+      return;
+    }
+    LogXTraceBrowserNetworkEvent(CreateXTraceBrowserNetworkEventJson(
+        "BrowserNetwork.redirect", *request_, redirect_info->new_url,
+        redirect_info->new_method));
+    request_->url = redirect_info->new_url;
+    request_->method = redirect_info->new_method;
+  }
+
+  void WillProcessResponse(const GURL& response_url,
+                           network::mojom::URLResponseHead* response_head,
+                           bool* defer) override {
+    if (!response_head || !request_) {
+      return;
+    }
+    LogXTraceBrowserNetworkEvent(CreateXTraceBrowserNetworkResponseEventJson(
+        *request_, response_url, *response_head));
+  }
+
+ private:
+  std::optional<network::ResourceRequest> request_;
+};
+
+class XTraceBrowserNetworkURLLoaderClient final
+    : public network::mojom::URLLoaderClient {
+ public:
+  XTraceBrowserNetworkURLLoaderClient(
+      const network::ResourceRequest& request,
+      mojo::PendingRemote<network::mojom::URLLoaderClient> client)
+      : request_(request), client_(std::move(client)) {}
+
+  XTraceBrowserNetworkURLLoaderClient(
+      const XTraceBrowserNetworkURLLoaderClient&) = delete;
+  XTraceBrowserNetworkURLLoaderClient& operator=(
+      const XTraceBrowserNetworkURLLoaderClient&) = delete;
+
+ private:
+  void OnReceiveEarlyHints(network::mojom::EarlyHintsPtr early_hints) override {
+    client_->OnReceiveEarlyHints(std::move(early_hints));
+  }
+
+  void OnReceiveResponse(
+      network::mojom::URLResponseHeadPtr response_head,
+      mojo::ScopedDataPipeConsumerHandle body,
+      std::optional<mojo_base::BigBuffer> cached_metadata) override {
+    if (response_head) {
+      LogXTraceBrowserNetworkEvent(CreateXTraceBrowserNetworkResponseEventJson(
+          request_, request_.url, *response_head));
+    }
+    client_->OnReceiveResponse(std::move(response_head), std::move(body),
+                               std::move(cached_metadata));
+  }
+
+  void OnReceiveRedirect(
+      const net::RedirectInfo& redirect_info,
+      network::mojom::URLResponseHeadPtr response_head) override {
+    LogXTraceBrowserNetworkEvent(CreateXTraceBrowserNetworkEventJson(
+        "BrowserNetwork.redirect", request_, redirect_info.new_url,
+        redirect_info.new_method));
+    request_.url = redirect_info.new_url;
+    request_.method = redirect_info.new_method;
+    client_->OnReceiveRedirect(redirect_info, std::move(response_head));
+  }
+
+  void OnUploadProgress(int64_t current_position,
+                        int64_t total_size,
+                        OnUploadProgressCallback ack_callback) override {
+    client_->OnUploadProgress(current_position, total_size,
+                              std::move(ack_callback));
+  }
+
+  void OnTransferSizeUpdated(int32_t transfer_size_diff) override {
+    client_->OnTransferSizeUpdated(transfer_size_diff);
+  }
+
+  void OnComplete(
+      const network::URLLoaderCompletionStatus& completion_status) override {
+    LogXTraceBrowserNetworkEvent(CreateXTraceBrowserNetworkCompleteEventJson(
+        request_, completion_status));
+    client_->OnComplete(completion_status);
+  }
+
+  network::ResourceRequest request_;
+  mojo::Remote<network::mojom::URLLoaderClient> client_;
+};
+
+mojo::PendingRemote<network::mojom::URLLoaderClient>
+CreateXTraceBrowserNetworkURLLoaderClientRemote(
+    const network::ResourceRequest& request,
+    mojo::PendingRemote<network::mojom::URLLoaderClient> client) {
+  mojo::PendingRemote<network::mojom::URLLoaderClient> wrapped_client;
+  mojo::PendingReceiver<network::mojom::URLLoaderClient> wrapped_receiver =
+      wrapped_client.InitWithNewPipeAndPassReceiver();
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<XTraceBrowserNetworkURLLoaderClient>(
+          request, std::move(client)),
+      std::move(wrapped_receiver));
+  return wrapped_client;
+}
