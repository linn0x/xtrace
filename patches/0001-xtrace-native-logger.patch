+constexpr char kXTraceFileEnv[] = "XTRACE_FILE";
+constexpr char kXTraceMaxBodyBytesEnv[] = "XTRACE_MAX_BODY_BYTES";
+constexpr char kXTraceMaxHeaderValueBytesEnv[] =
+    "XTRACE_MAX_HEADER_VALUE_BYTES";
+constexpr char kXTraceEnableSwitch[] = "xtrace-enable";
+constexpr char kXTraceFileSwitch[] = "xtrace-file";
