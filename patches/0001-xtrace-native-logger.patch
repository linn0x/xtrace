+      "\"result_key_ref\":%s}]",
+      XTraceLogger::QuoteJson(String(operation)).Utf8().c_str(),
+      result ? static_cast<int>(result->GetType()) : -1,
+      static_cast<unsigned long long>(XTraceIDBResultValueSize(result)),
+      result && result->GetType() == IDBAny::kKeyType
+          ? XTraceIDBResultKeyRefJson(result->Key()).Utf8().c_str()
+          : "null");
