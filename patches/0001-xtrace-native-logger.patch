+
+String XTraceCookieStoreWriteArgsJson(const CookieInit* options,
+                                      const KURL& cookie_url) {
+  const String name = StripHttpWhitespace(options->name());
+  const String value = StripHttpWhitespace(options->value());
+  const bool has_domain = !options->domain().IsNull();
+  const String domain = has_domain ? options->domain() : String();
+  const bool has_path = options->hasPath();
+  const String path = has_path ? options->path() : String();
+  const String cookie_url_string = cookie_url.GetString();
+  return String::Format(
+      "[{\"name\":%s,\"name_length\":%u,\"name_ref\":%s,"
+      "\"value\":%s,\"value_length\":%u,\"value_ref\":%s,"
+      "\"domain\":%s,\"domain_length\":%s,\"domain_ref\":%s,"
+      "\"path\":%s,\"path_length\":%s,\"path_ref\":%s,"
+      "\"cookie_url\":%s,\"cookie_url_ref\":%s,\"partitioned\":%s}]",
+      XTraceLogger::QuoteJson(name).Utf8().c_str(), name.length(),
+      XTraceLogger::StringHashRefJson(name).Utf8().c_str(),
+      XTraceLogger::QuoteJson(value).Utf8().c_str(), value.length(),
+      XTraceLogger::StringHashRefJson(value).Utf8().c_str(),
+      XTraceJsonStringOrNull(domain, has_domain).Utf8().c_str(),
+      XTraceJsonStringLengthOrNull(domain, has_domain).Utf8().c_str(),
+      XTraceJsonStringRefOrNull(domain, has_domain).Utf8().c_str(),
+      XTraceJsonStringOrNull(path, has_path).Utf8().c_str(),
+      XTraceJsonStringLengthOrNull(path, has_path).Utf8().c_str(),
+      XTraceJsonStringRefOrNull(path, has_path).Utf8().c_str(),
+      XTraceLogger::QuoteJson(cookie_url_string).Utf8().c_str(),
+      XTraceLogger::StringHashRefJson(cookie_url_string).Utf8().c_str(),
+      options->partitioned() ? "true" : "false");
+}
+
+String XTraceCookieResultMaterial(
+    const network::mojom::blink::CookieWithAccessResultPtr& cookie,
+    bool values) {
