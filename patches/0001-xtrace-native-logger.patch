+}  // namespace
+
+bool XTraceLogger::Enabled() {
+  return GetCachedConfig().enabled;
+}
+
+String XTraceLogger::QuoteJson(const String& value) {
+  return String::FromUtf8(QuoteJsonString(value.Utf8()));
+}
+
+String XTraceLogger::StringHashRefJson(const String& value) {
+  if (value.IsNull()) {
+    return String("null");
+  }
+  std::string ref = "string_ref:sha1:" + base::HexEncode(
+      base::SHA1HashString(value.Utf8()));
+  return String::FromUtf8(QuoteJsonString(ref));
+}
+
+String XTraceLogger::NetworkCorrelationKey(const String& method,
+                                           const String& url) {
+  std::string material = base::ToUpperASCII(method.Utf8()) + "\n" + url.Utf8();
+  return String::FromUtf8(Sha1Ref(material));
+}
+
+void XTraceLogger::LogCall(const char* api, const String& args_json) {
+  LogEvent("fingerprint", "call", api, args_json);
+}
+
+void XTraceLogger::LogCall(const char* category,
+                           const char* api,
+                           const String& args_json) {
+  LogEvent(category, "call", api, args_json);
+}
+
+void XTraceLogger::LogEvent(const char* category,
+                            const char* phase,
+                            const char* api,
+                            const String& args_json) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!CategoryEnabled(config, category)) {
+    return;
+  }
+
+  const uint64_t seq = NextSequenceNumber();
+  LogEventWithSequence(config, category, phase, api, args_json, seq,
+                       std::string_view(), true, std::string_view(),
+                       std::string_view());
+}
+
+void XTraceLogger::LogEventWithContext(const char* category,
+                                       const char* phase,
+                                       const char* api,
+                                       const String& args_json,
+                                       const String& frame_url,
+                                       const String& origin) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!CategoryEnabled(config, category)) {
+    return;
+  }
+
+  std::string frame_url_utf8 = frame_url.Utf8();
+  std::string origin_utf8 = origin.Utf8();
+  const uint64_t seq = NextSequenceNumber();
+  LogEventWithSequence(config, category, phase, api, args_json, seq,
+                       std::string_view(), true, frame_url_utf8, origin_utf8);
+}
+
+void XTraceLogger::LogEventNoStack(const char* category,
+                                   const char* phase,
+                                   const char* api,
+                                   const String& args_json) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!CategoryEnabled(config, category)) {
+    return;
+  }
+
+  const uint64_t seq = NextSequenceNumber();
+  LogEventWithSequence(config, category, phase, api, args_json, seq,
+                       std::string_view(), false, std::string_view(),
+                       std::string_view());
+}
+
+void XTraceLogger::LogEventNoStackWithContext(const char* category,
+                                              const char* phase,
+                                              const char* api,
+                                              const String& args_json,
+                                              const String& frame_url,
+                                              const String& origin) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!CategoryEnabled(config, category)) {
+    return;
+  }
+
+  std::string frame_url_utf8 = frame_url.Utf8();
+  std::string origin_utf8 = origin.Utf8();
+  const uint64_t seq = NextSequenceNumber();
+  LogEventWithSequence(config, category, phase, api, args_json, seq,
+                       std::string_view(), false, frame_url_utf8, origin_utf8);
+}
+
+void XTraceLogger::LogAssetEvent(const char* category,
+                                 const char* phase,
+                                 const char* api,
+                                 const String& args_json,
+                                 const char* kind,
+                                 const String& url,
+                                 const String& source) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!CategoryEnabled(config, category)) {
+    return;
+  }
+  if (IsInternalScriptUrl(url)) {
+    return;
+  }
+
+  const uint64_t seq = NextSequenceNumber();
+  std::string extra_fields =
+      BuildScriptAssetFieldsAndSend(config, kind, url, source, seq);
+  LogEventWithSequence(config, category, phase, api, args_json, seq,
+                       extra_fields, true, std::string_view(),
+                       std::string_view());
+}
+
+void XTraceLogger::LogEventWithOptionalAsset(const char* category,
+                                             const char* phase,
+                                             const char* api,
+                                             const String& args_json,
+                                             const char* kind,
+                                             const String& url,
+                                             const String& source) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!CategoryEnabled(config, category)) {
+    return;
+  }
+
+  const uint64_t seq = NextSequenceNumber();
+  std::string extra_fields;
+  if (!IsInternalScriptUrl(url)) {
+    extra_fields = BuildScriptAssetFieldsAndSend(config, kind, url, source, seq);
+  }
+  LogEventWithSequence(config, category, phase, api, args_json, seq,
+                       extra_fields, false, std::string_view(),
+                       std::string_view());
+}
+
+void XTraceLogger::LogEventWithOptionalAssetAndContext(
+    const char* category,
+    const char* phase,
+    const char* api,
+    const String& args_json,
+    const char* kind,
+    const String& url,
+    const String& source,
+    const String& frame_url,
+    const String& origin) {
+  const XTraceConfig& config = GetCachedConfig();
+  if (!CategoryEnabled(config, category)) {
+    return;
+  }
+
+  std::string frame_url_utf8 = frame_url.Utf8();
+  std::string origin_utf8 = origin.Utf8();
+  const uint64_t seq = NextSequenceNumber();
+  std::string extra_fields;
+  if (!IsInternalScriptUrl(url)) {
+    extra_fields = BuildScriptAssetFieldsAndSend(config, kind, url, source, seq);
+  }
+  LogEventWithSequence(config, category, phase, api, args_json, seq,
+                       extra_fields, false, frame_url_utf8, origin_utf8);
+}
