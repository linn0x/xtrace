+namespace blink {
+namespace {
+
+constexpr char kEnableEnv[] = "XTRACE_ENABLE";
+constexpr char kFileEnv[] = "XTRACE_FILE";
+constexpr char kCategoriesEnv[] = "XTRACE_CATEGORIES";
+constexpr char kCaptureValuesEnv[] = "XTRACE_CAPTURE_VALUES";
+constexpr char kCaptureAssetsEnv[] = "XTRACE_CAPTURE_ASSETS";
+constexpr char kEnableSwitch[] = "xtrace-enable";
+constexpr char kFileSwitch[] = "xtrace-file";
+constexpr char kCategoriesSwitch[] = "xtrace-categories";
+constexpr char kCaptureValuesSwitch[] = "xtrace-capture-values";
+constexpr char kCaptureAssetsSwitch[] = "xtrace-capture-assets";
+
+struct XTraceConfig {
+  bool enabled = false;
+  std::string categories = "reverse,fingerprint";
+  std::string capture_values = "full";
+  std::string capture_assets = "full";
+  std::string session_id;
+  std::string trace_stem;
+};
+
+std::optional<base::FilePath> ReadTraceFilePathFromRuntime() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kEnableSwitch)) {
+    base::FilePath trace_file = command_line->GetSwitchValuePath(kFileSwitch);
+    if (!trace_file.empty()) {
+      return trace_file;
+    }
+  }
+
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled = env->GetVar(kEnableEnv);
+  if (!enabled || *enabled != "1") {
+    return std::nullopt;
+  }
+
+  std::optional<std::string> trace_file = env->GetVar(kFileEnv);
+  if (!trace_file || trace_file->empty()) {
+    return std::nullopt;
+  }
+
+  return base::FilePath::FromUTF8Unsafe(*trace_file);
+}
+
+std::optional<std::string> ReadRuntimeString(const char* switch_name,
+                                             const char* env_name) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switch_name)) {
+    std::string value = command_line->GetSwitchValueASCII(switch_name);
+    if (!value.empty()) {
+      return value;
+    }
+  }
+
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::string env_name_string(env_name);
+  std::optional<std::string> value = env->GetVar(env_name_string);
+  if (value && !value->empty()) {
+    return value;
+  }
+
+  return std::nullopt;
+}
+
+std::string MakeSessionId() {
+  const int64_t wall_time_us =
+      (base::Time::Now() - base::Time::UnixEpoch()).InMicroseconds();
+  return base::NumberToString(base::GetCurrentProcId()) + "-" +
+         base::NumberToString(wall_time_us);
+}
+
+XTraceConfig ReadConfigFromRuntime() {
+  XTraceConfig config;
+  std::optional<base::FilePath> trace_file_path = ReadTraceFilePathFromRuntime();
+  config.enabled = trace_file_path.has_value();
+  config.categories = ReadRuntimeString(kCategoriesSwitch, kCategoriesEnv)
+                          .value_or("reverse,fingerprint");
+  config.capture_values =
+      ReadRuntimeString(kCaptureValuesSwitch, kCaptureValuesEnv)
+          .value_or("full");
+  config.capture_assets =
+      ReadRuntimeString(kCaptureAssetsSwitch, kCaptureAssetsEnv)
+          .value_or("full");
+  config.session_id = MakeSessionId();
+  if (trace_file_path) {
+    config.trace_stem =
+        trace_file_path->BaseName().RemoveExtension().AsUTF8Unsafe();
+  }
+  return config;
+}
+
+const XTraceConfig& GetCachedConfig() {
+  static base::NoDestructor<XTraceConfig> config(ReadConfigFromRuntime());
+  return *config;
+}
+
+std::string QuoteJsonString(std::string_view value) {
+  std::string quoted;
+  base::EscapeJSONString(value, /*put_in_quotes=*/true, &quoted);
+  return quoted;
+}
+
+bool CategoryEnabled(const XTraceConfig& config, std::string_view category) {
+  if (!config.enabled || category.empty()) {
+    return false;
+  }
+  if (config.categories == "all") {
+    return true;
+  }
+
+  for (std::string_view token :
+       base::SplitStringPiece(config.categories, ",", base::TRIM_WHITESPACE,
+                              base::SPLIT_WANT_NONEMPTY)) {
+    if (token == category) {
+      return true;
+    }
+  }
+  return false;
+}
+
+uint64_t NextSequenceNumber() {
+  static std::atomic<uint64_t> sequence{0};
+  return ++sequence;
+}
+
+std::string Sha1Ref(std::string_view value) {
+  return "sha1:" + base::HexEncode(base::SHA1HashString(value));
+}
+
+std::string V8StringToUtf8(v8::Isolate* isolate, v8::Local<v8::String> value) {
+  if (value.IsEmpty()) {
+    return std::string();
+  }
+  v8::String::Utf8Value utf8(isolate, value);
+  if (!*utf8) {
+    return std::string();
+  }
+  return std::string(*utf8, utf8.length());
+}
+
+std::string CaptureJavaScriptStack() {
+  v8::Isolate* isolate = v8::Isolate::TryGetCurrent();
+  if (!isolate) {
+    return "[]";
+  }
+
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::StackTrace> stack_trace =
+      v8::StackTrace::CurrentStackTrace(isolate, 16,
+                                        v8::StackTrace::kDetailed);
+  if (stack_trace.IsEmpty() || stack_trace->GetFrameCount() == 0) {
+    return "[]";
+  }
+
+  std::string stack;
+  stack.append("[");
+  for (int i = 0; i < stack_trace->GetFrameCount(); ++i) {
+    v8::Local<v8::StackFrame> frame = stack_trace->GetFrame(isolate, i);
+    if (frame.IsEmpty()) {
+      continue;
+    }
+    if (stack.size() > 1) {
+      stack.append(",");
+    }
+    stack.append("{\"function\":");
+    stack.append(QuoteJsonString(V8StringToUtf8(
+        isolate, frame->GetFunctionName())));
+    stack.append(",\"url\":");
+    stack.append(QuoteJsonString(V8StringToUtf8(
+        isolate, frame->GetScriptNameOrSourceURL())));
+    stack.append(",\"line\":");
+    stack.append(base::NumberToString(frame->GetLineNumber()));
+    stack.append(",\"column\":");
+    stack.append(base::NumberToString(frame->GetColumn()));
+    stack.append(",\"script_id\":");
+    stack.append(base::NumberToString(frame->GetScriptId()));
+    stack.append(",\"is_eval\":");
+    stack.append(frame->IsEval() ? "true" : "false");
+    stack.append(",\"is_constructor\":");
+    stack.append(frame->IsConstructor() ? "true" : "false");
+    stack.append("}");
+  }
+  stack.append("]");
+  return stack;
+}
+
+bool CaptureAssetsEnabled(const XTraceConfig& config) {
+  return config.capture_assets == "summary" || config.capture_assets == "full";
+}
+
+bool CaptureFullAssetsEnabled(const XTraceConfig& config) {
+  return config.capture_assets == "full";
+}
+
+bool IsInternalScriptUrl(const String& url) {
+  std::string url_utf8 = url.Utf8();
+  return url_utf8.starts_with("chrome://") ||
+         url_utf8.starts_with("chrome-untrusted://") ||
+         url_utf8.starts_with("devtools://") ||
+         url_utf8.starts_with("chrome-extension://");
+}
+
+std::string SanitizeAssetIdForPath(std::string_view asset_id) {
+  std::string safe;
+  safe.reserve(asset_id.size());
+  for (char c : asset_id) {
+    unsigned char uc = static_cast<unsigned char>(c);
+    safe.push_back(std::isalnum(uc) ? c : '_');
+  }
+  return safe.empty() ? "asset" : safe;
+}
+
+mojom::blink::XTraceHost* GetXTraceHost();
+
+bool AssetAlreadySent(std::string_view asset_id) {
+  thread_local auto* sent_assets = new std::unordered_set<std::string>();
+  auto [_, inserted] = sent_assets->insert(std::string(asset_id));
+  return !inserted;
+}
+
+std::string BuildScriptAssetFieldsAndSend(const XTraceConfig& config,
+                                          const char* kind,
+                                          const String& url,
+                                          const String& source,
+                                          uint64_t first_seq) {
+  if (!CaptureAssetsEnabled(config) || source.empty()) {
+    return std::string();
+  }
+
+  std::string source_utf8 = source.Utf8();
+  std::string url_utf8 = url.Utf8();
+  std::string kind_string(kind ? kind : "unknown");
+  std::string source_hash = Sha1Ref(source_utf8);
+  std::string asset_hash_input = kind_string + "\n" + url_utf8 + "\n" + source_utf8;
+  std::string asset_id = Sha1Ref(asset_hash_input);
+
+  std::string content_path;
+  std::string content;
+  if (CaptureFullAssetsEnabled(config)) {
+    std::string trace_stem =
+        config.trace_stem.empty() ? "trace_unknown" : config.trace_stem;
+    content_path = "assets/" + trace_stem + "/" +
+                   SanitizeAssetIdForPath(asset_id) + ".js";
+    content = source_utf8;
+  }
+
+  if (!AssetAlreadySent(asset_id)) {
+    std::string manifest;
+    manifest.append("{\"asset_id\":");
+    manifest.append(QuoteJsonString(asset_id));
+    manifest.append(",\"kind\":");
+    manifest.append(QuoteJsonString(kind_string));
+    manifest.append(",\"url\":");
+    manifest.append(QuoteJsonString(url_utf8));
+    manifest.append(",\"content_path\":");
+    manifest.append(QuoteJsonString(content_path));
+    manifest.append(",\"sha1\":");
+    manifest.append(QuoteJsonString(source_hash));
+    manifest.append(",\"size\":");
+    manifest.append(base::NumberToString(source_utf8.size()));
+    manifest.append(",\"truncated\":");
+    manifest.append("false");
+    manifest.append(",\"first_seq\":");
+    manifest.append(base::NumberToString(first_seq));
+    manifest.append(",\"frame_url\":\"\"");
+    manifest.append(",\"origin\":\"\"");
+    manifest.append(",\"original_size\":");
+    manifest.append(base::NumberToString(source_utf8.size()));
+    manifest.append(",\"source\":");
+    manifest.append(QuoteJsonString(source_utf8));
+    manifest.append(",\"retrieval_status\":");
+    manifest.append(QuoteJsonString(CaptureFullAssetsEnabled(config)
+                                        ? "captured"
+                                        : "summary"));
+    manifest.append("}");
+    GetXTraceHost()->LogAsset(String::FromUtf8(content_path),
+                              String::FromUtf8(manifest),
+                              String::FromUtf8(content));
+  }
+
+  std::string fields;
+  fields.append("\"asset_id\":");
+  fields.append(QuoteJsonString(asset_id));
+  fields.append(",\"source_hash\":");
+  fields.append(QuoteJsonString(source_hash));
+  fields.append(",\"source\":");
+  fields.append(QuoteJsonString(source_utf8));
+  fields.append(",\"script_url\":");
+  fields.append(QuoteJsonString(url_utf8));
+  return fields;
+}
+
+mojom::blink::XTraceHost* GetXTraceHost() {
+  thread_local mojo::Remote<mojom::blink::XTraceHost> host;
+  if (!host.is_bound()) {
+    Platform::Current()->GetBrowserInterfaceBroker()->GetInterface(
+        host.BindNewPipeAndPassReceiver());
+  }
+  return host.get();
+}
+
+void LogEventWithSequence(const XTraceConfig& config,
+                          const char* category,
+                          const char* phase,
+                          const char* api,
+                          const String& args_json,
+                          uint64_t seq,
+                          std::string_view extra_fields,
+                          bool capture_stack,
+                          std::string_view frame_url,
+                          std::string_view origin) {
+  const int64_t wall_time_us =
+      (base::Time::Now() - base::Time::UnixEpoch()).InMicroseconds();
+  const int64_t mono_time_us =
+      base::TimeTicks::Now().since_origin().InMicroseconds();
+  std::string event_id = config.session_id + ":" + base::NumberToString(seq);
+
+  std::string args = args_json.Utf8();
+  std::string stack_json = capture_stack ? CaptureJavaScriptStack() : "[]";
+
+  std::string line;
+  line.append("{\"schema_version\":1");
+  line.append(",\"event_id\":");
+  line.append(QuoteJsonString(event_id));
+  line.append(",\"session_id\":");
+  line.append(QuoteJsonString(config.session_id));
+  line.append(",\"seq\":");
+  line.append(base::NumberToString(seq));
+  line.append(",\"session_seq\":");
+  line.append(base::NumberToString(seq));
+  line.append(",\"t\":");
+  line.append(QuoteJsonString(phase));
+  line.append(",\"ts\":");
+  line.append(base::NumberToString(wall_time_us));
+  line.append(",\"wall_time_us\":");
+  line.append(base::NumberToString(wall_time_us));
+  line.append(",\"mono_time_us\":");
+  line.append(base::NumberToString(mono_time_us));
+  line.append(",\"category\":");
+  line.append(QuoteJsonString(category));
+  line.append(",\"phase\":");
+  line.append(QuoteJsonString(phase));
+  line.append(",\"pid\":");
+  line.append(base::NumberToString(base::GetCurrentProcId()));
+  line.append(",\"tid\":");
+  line.append(base::NumberToString(base::PlatformThread::CurrentId().raw()));
+  line.append(",\"api\":");
+  line.append(QuoteJsonString(api));
+  line.append(",\"args\":");
+  line.append(args);
+  line.append(",\"stack\":");
+  line.append(stack_json);
+  line.append(",\"frame_url\":");
+  line.append(QuoteJsonString(frame_url));
+  line.append(",\"origin\":");
+  line.append(QuoteJsonString(origin));
+  line.append(",\"result\":null");
+  line.append(",\"error\":null");
+  line.append(",\"truncated\":false");
+  if (!extra_fields.empty()) {
+    line.append(",");
+    line.append(extra_fields);
+  }
+  line.append("}\n");
+
+  // LogBatch is intentionally not used yet; per-event Log keeps current
+  // ordering/compatibility until renderer-side buffering lands.
+  GetXTraceHost()->Log(String::FromUtf8(line));
+}
