+String XTraceFormDataEffectiveBlobFilename(Blob* blob,
+                                           const String& filename) {
+  if (!blob)
+    return filename;
+  if (auto* file = DynamicTo<File>(blob)) {
+    if (filename.IsNull())
+      return file->name();
+    return filename;
+  }
+  if (filename.IsNull())
+    return "blob";
+  return filename;
+}
+
+String XTraceFormDataEntryJson(const FormData::Entry& entry) {
+  const String& name = entry.name();
+  if (entry.IsString()) {
+    const String& value = entry.Value();
+    return String::Format(
+        "{\"name\":%s,\"name_length\":%u,\"name_ref\":%s,"
+        "\"value_kind\":\"string\",\"value\":%s,\"value_length\":%u,"
+        "\"value_ref\":%s}",
+        XTraceLogger::QuoteJson(name).Utf8().c_str(),
+        XTraceFormDataStringLength(name),
+        XTraceLogger::StringHashRefJson(name).Utf8().c_str(),
+        XTraceLogger::QuoteJson(value).Utf8().c_str(),
+        XTraceFormDataStringLength(value),
+        XTraceLogger::StringHashRefJson(value).Utf8().c_str());
+  }
+
+  Blob* blob = entry.GetBlob();
+  File* file = entry.GetFile();
+  const String filename =
+      file ? file->name()
+           : XTraceFormDataEffectiveBlobFilename(blob, entry.Filename());
+  const String blob_type = blob ? blob->type() : String();
+  const String blob_uuid = blob ? blob->Uuid() : String();
+  const uint64_t blob_size = blob ? blob->size() : 0;
+  return String::Format(
+      "{\"name\":%s,\"name_length\":%u,\"name_ref\":%s,"
+      "\"value_kind\":\"blob\",\"filename\":%s,\"filename_length\":%u,"
+      "\"filename_ref\":%s,\"blob_type\":%s,\"blob_type_length\":%u,"
+      "\"blob_type_ref\":%s,\"blob_size\":%llu,\"blob_uuid\":%s,"
+      "\"blob_uuid_ref\":%s}",
+      XTraceLogger::QuoteJson(name).Utf8().c_str(),
+      XTraceFormDataStringLength(name),
+      XTraceLogger::StringHashRefJson(name).Utf8().c_str(),
+      XTraceLogger::QuoteJson(filename).Utf8().c_str(),
+      XTraceFormDataStringLength(filename),
+      XTraceLogger::StringHashRefJson(filename).Utf8().c_str(),
+      XTraceLogger::QuoteJson(blob_type).Utf8().c_str(),
+      XTraceFormDataStringLength(blob_type),
+      XTraceLogger::StringHashRefJson(blob_type).Utf8().c_str(),
+      static_cast<unsigned long long>(blob_size),
+      XTraceLogger::QuoteJson(blob_uuid).Utf8().c_str(),
+      XTraceLogger::StringHashRefJson(blob_uuid).Utf8().c_str());
+}
+
+String XTraceFormDataEntriesJson(const FormData& form_data) {
+  StringBuilder builder;
+  builder.Append("[");
+  for (wtf_size_t i = 0; i < form_data.Entries().size(); ++i) {
+    if (i > 0)
+      builder.Append(",");
+    builder.Append(XTraceFormDataEntryJson(*form_data.Entries()[i]));
+  }
+  builder.Append("]");
+  return builder.ToString();
+}
