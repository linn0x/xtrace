+
+String XTraceClientMessageType(const ScriptValue& message) {
+  if (message.IsEmpty()) {
+    return String("empty");
+  }
+  v8::Local<v8::Value> value = message.V8Value();
+  if (value.IsEmpty()) {
+    return String("empty");
+  }
+  if (value->IsUndefined()) {
+    return String("undefined");
+  }
+  if (value->IsNull()) {
+    return String("null");
+  }
+  if (value->IsString()) {
+    return String("string");
+  }
+  if (value->IsBoolean()) {
+    return String("boolean");
+  }
+  if (value->IsNumber()) {
+    return String("number");
+  }
+  if (value->IsBigInt()) {
+    return String("bigint");
+  }
+  if (value->IsArrayBufferView()) {
+    return String("array_buffer_view");
+  }
+  if (value->IsArrayBuffer()) {
+    return String("array_buffer");
+  }
+  if (value->IsArray()) {
+    return String("array");
+  }
+  if (value->IsFunction()) {
+    return String("function");
+  }
+  if (value->IsObject()) {
+    return String("object");
+  }
+  return String("unknown");
+}
+
+String XTraceClientMessageValue(ScriptState* script_state,
+                                const ScriptValue& message) {
+  if (!script_state || message.IsEmpty()) {
+    return String();
+  }
+  v8::Local<v8::Value> value = message.V8ValueFor(script_state);
+  if (value.IsEmpty()) {
+    return String();
+  }
+  if (value->IsUndefined()) {
+    return String("undefined");
+  }
+  if (value->IsNull()) {
+    return String("null");
+  }
+  if (value->IsString()) {
+    return ToCoreString(script_state->GetIsolate(), value.As<v8::String>());
+  }
+  if (value->IsBoolean()) {
+    return value.As<v8::Boolean>()->Value() ? String("true") : String("false");
+  }
+  if (value->IsNumber()) {
+    return String::Number(value.As<v8::Number>()->Value());
+  }
+  return String();
+}
+
+String XTraceSerializedDataHex(SerializedScriptValue* serialized) {
+  if (!serialized) {
+    return String();
+  }
+  return String::FromUtf8(base::HexEncode(serialized->GetWireData()));
+}
+
+wtf_size_t XTraceClientTransferCount(const Transferables& transferables) {
+  return transferables.array_buffers.size() +
+         transferables.element_images.size() +
+         transferables.image_bitmaps.size() +
+         transferables.offscreen_canvases.size() +
+         transferables.message_ports.size() +
+         transferables.mojo_handles.size() +
+         transferables.readable_streams.size() +
+         transferables.writable_streams.size() +
+         transferables.transform_streams.size() +
+         transferables.media_stream_tracks.size();
+}
+
+void LogXTraceServiceWorkerClientPostMessage(
+    ScriptState* script_state,
+    const String& client_id,
+    const String& client_url,
+    mojom::ServiceWorkerClientType client_type,
+    const ScriptValue& message,
+    const Transferables& transferables,
+    SerializedScriptValue* serialized_message) {
+  const String message_type = XTraceClientMessageType(message);
+  const String message_value = XTraceClientMessageValue(script_state, message);
+  const String message_value_json =
+      message_value.IsNull() ? String("null")
+                             : XTraceLogger::QuoteJson(message_value);
+  const String message_ref_json =
+      message_value.IsNull()
+          ? String("null")
+          : XTraceLogger::StringHashRefJson(message_value);
+  const String serialized_data_hex =
+      XTraceSerializedDataHex(serialized_message);
+  const String serialized_data_hex_json =
+      serialized_data_hex.IsNull()
+          ? String("null")
+          : XTraceLogger::QuoteJson(serialized_data_hex);
+  const String serialized_data_ref_json =
+      serialized_data_hex.IsNull()
+          ? String("null")
+          : XTraceLogger::StringHashRefJson(serialized_data_hex);
+  const String client_type_json = XTraceLogger::QuoteJson(
+      String(XTraceServiceWorkerClientType(client_type)));
+  XTraceLogger::LogEvent(
+      "reverse", "call", "ServiceWorkerClient.postMessage",
+      String::Format(
+          "[{\"direction\":\"service_worker_to_client\",\"client_id\":%s,"
+          "\"client_url_ref\":%s,\"client_type\":%s,"
+          "\"transfer_count\":%u,\"serialized_size\":%llu,"
+          "\"message_type\":%s,\"message_value\":%s,\"message_ref\":%s,"
+          "\"serialized_data_hex\":%s,\"serialized_data_ref\":%s}]",
+          XTraceLogger::QuoteJson(client_id).Utf8().c_str(),
+          XTraceLogger::StringHashRefJson(client_url).Utf8().c_str(),
+          client_type_json.Utf8().c_str(),
+          static_cast<unsigned>(XTraceClientTransferCount(transferables)),
+          serialized_message ? static_cast<unsigned long long>(
+                                   serialized_message->DataLengthInBytes())
+                             : 0,
+          XTraceLogger::QuoteJson(message_type).Utf8().c_str(),
+          message_value_json.Utf8().c_str(),
+          message_ref_json.Utf8().c_str(),
+          serialized_data_hex_json.Utf8().c_str(),
+          serialized_data_ref_json.Utf8().c_str()));
