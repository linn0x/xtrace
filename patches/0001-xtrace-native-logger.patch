+
+String XTraceFormDataStringArrayJson(const Vector<String>& values) {
+  StringBuilder builder;
+  builder.Append("[");
+  for (wtf_size_t i = 0; i < values.size(); ++i) {
+    if (i > 0)
+      builder.Append(",");
+    builder.Append(XTraceLogger::QuoteJson(values[i]));
+  }
+  builder.Append("]");
+  return builder.ToString();
+}
+
+String XTraceFormDataStringRefArrayJson(const Vector<String>& values) {
+  StringBuilder builder;
+  builder.Append("[");
+  for (wtf_size_t i = 0; i < values.size(); ++i) {
+    if (i > 0)
+      builder.Append(",");
+    builder.Append(XTraceLogger::StringHashRefJson(values[i]));
+  }
+  builder.Append("]");
+  return builder.ToString();
+}
+
+String XTraceFormDataStringLengthArrayJson(const Vector<String>& values) {
